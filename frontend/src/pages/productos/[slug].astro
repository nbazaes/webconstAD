---
import BaseLayout from '../../layouts/BaseLayout.astro'

const apiOrigin = import.meta.env.API_ORIGIN || import.meta.env.BUILD_API_ORIGIN || 'http://127.0.0.1:8000'
const { slug } = Astro.params
const paymentDetailsResponse = await fetch(`${apiOrigin}/api/pagos/detalle/`)
const paymentDetails = paymentDetailsResponse.ok ? await paymentDetailsResponse.json() : null
const bankAccount = paymentDetails?.bank_account || '<bank_account>'
const bankAccountDetails = paymentDetails?.details || {}
const response = await fetch(`${apiOrigin}/api/productos/${slug}/`)
const producto = response.ok ? await response.json() : null

const pageTitle = `${producto?.nombre || 'Producto'} | Productos | Constant Archivos Digitales`
const formattedPrice = producto?.precio != null
  ? String(parseInt(producto.precio)).replace(/\B(?=(\d{3})+(?!\d))/g, ' ')
  : null
---

<BaseLayout title={pageTitle} page="productos">
  <main class="content">
    {producto ? (
      <>
        <section class="products-hero text-block">
          <div class="product-hero">
            <div class="product-hero__image">
              {producto.imagen ? (
                <img src={producto.imagen} alt={producto.descripcion || producto.nombre} width="400" height="263" />
              ) : (
                <img src="/static/web/assets/hero1.webp" alt={producto.nombre} width="400" height="263" />
              )}
            </div>
            <div class="product-hero__content">
              {producto.coleccion_descripcion ? (
                <div class="lead">
                  <img src={producto.coleccion_descripcion} alt={producto.coleccion || 'Coleccion'} width="400" height="263" loading="lazy" />
                </div>
              ) : null}
            </div>
            {producto.preview_imagen ? (
              <div class="product-hero__preview">
                <img src={producto.preview_imagen} alt={producto.nombre || 'Preview'} width="380" height="250" loading="lazy" />
              </div>
            ) : null}
          </div>
        </section>

        <section class="product-title-block">
          <h2><span>{producto.coleccion || 'Coleccion'}</span> <span>{producto.nombre}</span></h2>
        </section>
        <section class="product-detail" data-product-id={producto.id}>
          <ul class="product-meta-list">
            {producto.descripcion ? <li>{producto.descripcion}</li> : null}
            {producto.paginas ? <li>{producto.paginas} pág.</li> : null}
            {formattedPrice ? <li class="product-price">${formattedPrice}</li> : null}
          </ul>
          <div class="product-actions">
            <button class="btn btn-buy" type="button" data-buy-button>Comprar</button>
            <button class="btn btn-cart" type="button" data-add-to-cart>Añadir al carrito</button>
          </div>
        </section>
      </>
    ) : (
      <section class="products-hero text-block">
        <p>No se encontró este producto.</p>
      </section>
    )}
  </main>
</BaseLayout>

<style>
  .product-title-block {
    max-width: 900px;
    margin: 10px auto 20px;
    padding: 0 20px;
    font-family: 'PT Serif', serif;
  }

  .product-title-block h2 {
    margin: 0;
    font-size: 1.8rem;
  }

  .product-title-block h2 span:first-child {
    font-weight: 700;
  }

  .product-title-block h2 span:last-child {
    font-weight: 400;
  }

  .products-hero.text-block {
    max-width: 1320px;
  }

  .product-hero {
    display: grid;
    grid-template-columns: minmax(0, 400px) minmax(0, 1.2fr) minmax(0, 380px);
    column-gap: 0;
    row-gap: 24px;
    align-items: center;
  }

  .product-hero__image,
  .product-hero__preview {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-hero__image {
    margin-right: 24px;
  }

  .product-hero__image img {
    width: 100%;
    max-width: 400px;
    height: auto;
    object-fit: contain;
  }

  .product-hero__preview img {
    width: 100%;
    max-width: 380px;
    height: auto;
    object-fit: contain;
  }

  .product-hero__content .lead img {
    display: block;
    max-width: 400px;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .product-detail {
    max-width: 900px;
    margin: 0 auto 40px;
    padding: 0 20px;
    font-family: 'PT Serif', serif;
  }

  .product-meta-list {
    margin: 0;
    padding-left: 18px;
  }

  .product-meta-list li {
    font-size: 1.4rem;
    line-height: 1.5;
  }

  .product-meta-list .product-price {
    font-size: 1.68rem;
    font-weight: 700;
  }

  .product-actions {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
    margin-top: 18px;
  }

  .btn-buy {
    font-size: 1.05rem;
    letter-spacing: 0.02em;
  }

  .btn-cart {
    background: #6a5f55;
    font-size: 1.05rem;
    letter-spacing: 0.02em;
  }

  .btn-cart:disabled {
    opacity: 0.6;
    pointer-events: none;
  }

  .buy-modal {
    position: fixed;
    inset: 0;
    z-index: 2600;
    display: grid;
    place-items: center;
  }

  .buy-modal[hidden] {
    display: none;
  }

  .buy-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(9, 10, 10, 0.28);
    backdrop-filter: blur(4px);
  }

  .buy-modal__panel {
    position: relative;
    width: min(460px, calc(100vw - 32px));
    background: #ffffff;
    border: 1px solid #e2d7ce;
    border-radius: 16px;
    padding: 24px;
    text-align: left;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
    z-index: 1;
  }

  .buy-modal__panel h3 {
    margin: 0;
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    color: #243233;
  }

  .buy-modal__details {
    text-align: left;
  }

  .buy-modal__lead {
    margin: 10px 0 16px;
    font-size: 0.98rem;
    color: #6a5f55;
    line-height: 1.5;
  }

  .buy-modal__list {
    margin: 0;
    display: grid;
    grid-template-columns: 140px minmax(0, 1fr);
    gap: 10px 14px;
    align-items: start;
    background: #fffdfb;
    border: 1px solid #ece3dc;
    border-radius: 12px;
    padding: 14px 16px;
  }

  .buy-modal__list div {
    display: contents;
  }

  .buy-modal__list dt {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #8a7f75;
    font-weight: 700;
    padding-top: 2px;
  }

  .buy-modal__list dd {
    margin: 0;
    font-size: 0.98rem;
    color: #2d2622;
    font-weight: 600;
    word-break: break-word;
  }

  .buy-modal__note {
    margin: 18px 0 0;
    padding: 14px 16px;
    background: #f8f3ee;
    border-left: 4px solid #d9bfbf;
    border-radius: 0 8px 8px 0;
    color: #5a4f45;
    line-height: 1.6;
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .buy-modal__actions {
    margin-top: 18px;
    display: flex;
    justify-content: center;
  }

  .buy-modal__actions .btn {
    width: 100%;
    justify-content: center;
    padding: 12px 16px;
  }

  .buy-modal__details {
    margin-top: 10px;
  }

  .buy-modal__note a {
    color: #243233;
    text-decoration: underline;
    font-weight: 700;
  }

  .buy-modal__panel > h3::after {
    content: '';
    display: block;
    width: 46px;
    height: 2px;
    margin-top: 6px;
    background: #d9bfbf;
    border-radius: 1px;
  }

  @media (max-width: 600px) {
    .buy-modal__panel {
      padding: 18px;
    }

    .buy-modal__list {
      grid-template-columns: 1fr;
      gap: 4px 0;
    }

    .buy-modal__list dt {
      margin-top: 10px;
    }

    .buy-modal__list dt:first-of-type {
      margin-top: 0;
    }
  }

  @media (max-width: 700px) {
    .product-title-block h2 {
      font-size: 1.4rem;
      text-align: center;
    }

    .product-hero {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .product-hero__image img {
      max-width: 260px;
    }

    .product-hero__preview img {
      max-width: 260px;
    }

    .product-hero__content .lead img {
      max-width: 320px;
    }
  }
</style>

  <div class="buy-modal" data-buy-modal hidden>
  <div class="buy-modal__backdrop" data-buy-close></div>
  <div class="buy-modal__panel" role="dialog" aria-modal="true" aria-labelledby="buy-modal-title">
    <h3 id="buy-modal-title">Comprar</h3>
    <div class="buy-modal__details">
      <p class="buy-modal__lead">Transfiere a:</p>
      <dl class="buy-modal__list">
        <div>
          <dt>Nombre completo</dt>
          <dd>{bankAccountDetails.nombre_completo || '—'}</dd>
        </div>
        <div>
          <dt>RUT</dt>
          <dd>{bankAccountDetails.rut || '—'}</dd>
        </div>
        <div>
          <dt>Email</dt>
          <dd>{bankAccountDetails.email || '—'}</dd>
        </div>
        <div>
          <dt>Tipo de cuenta</dt>
          <dd>{bankAccountDetails.tipo_cuenta || '—'}</dd>
        </div>
        <div>
          <dt>Banco</dt>
          <dd>{bankAccountDetails.banco || '—'}</dd>
        </div>
        <div>
          <dt>Num. de cuenta</dt>
          <dd>{bankAccountDetails.numero_cuenta || '—'}</dd>
        </div>
      </dl>
      <p class="buy-modal__note">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8a7f75" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        <span>Envía el comprobante por Instagram a <a href="https://www.instagram.com/constantdesigns" target="_blank" rel="noreferrer">@constantdesigns</a>.</span>
      </p>
    </div>
    <div class="buy-modal__actions">
      <button class="btn" type="button" data-buy-close>Entendido</button>
    </div>
  </div>
</div>

<script>
  const buyButton = document.querySelector('[data-buy-button]')
  const buyModal = document.querySelector('[data-buy-modal]')
  const buyClosers = document.querySelectorAll('[data-buy-close]')
  const addToCartBtn = document.querySelector('[data-add-to-cart]')
  const productSection = document.querySelector('[data-product-id]')
  const productId = productSection?.dataset.productId

  const backendOrigin = window.location.origin
  const backendUrl = (path) => `${backendOrigin}${path}`

  const closeBuyModal = () => {
    buyModal?.setAttribute('hidden', '')
  }

  buyButton?.addEventListener('click', () => buyModal?.removeAttribute('hidden'))
  buyClosers.forEach((button) => button.addEventListener('click', closeBuyModal))

  addToCartBtn?.addEventListener('click', async () => {
    if (!productId) return

    const sessionRes = await fetch(backendUrl('/api/auth/session/'), { credentials: 'include' })
    const session = await sessionRes.json()

    if (!session.authenticated) {
      const authModal = document.querySelector('[data-auth-modal]')
      if (authModal) {
        authModal.querySelectorAll('[data-auth-view]').forEach((s) => {
          s.hidden = s.getAttribute('data-auth-view') !== 'login'
        })
        authModal.removeAttribute('hidden')
      }
      return
    }

    addToCartBtn.disabled = true
    addToCartBtn.textContent = 'Agregando…'

    try {
      const formData = new URLSearchParams()
      formData.append('producto_id', productId)

      const res = await fetch(backendUrl('/api/cart/add/'), {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: formData,
      })

      const data = await res.json()

      if (data.ok) {
        if (data.created) {
          addToCartBtn.textContent = '✓ Agregado'
          document.dispatchEvent(new CustomEvent('cart:updated'))
          if (window.peekCart) window.peekCart()
          setTimeout(() => {
            addToCartBtn.textContent = 'Añadir al carrito'
            addToCartBtn.disabled = false
          }, 2000)
        } else {
          addToCartBtn.textContent = 'Añadir al carrito'
          addToCartBtn.disabled = false
          window.showStyledAlert?.('Este producto ya está en tu carrito.')
        }
      } else {
        addToCartBtn.textContent = 'Error'
        setTimeout(() => {
          addToCartBtn.textContent = 'Añadir al carrito'
          addToCartBtn.disabled = false
        }, 2000)
      }
    } catch {
      addToCartBtn.textContent = 'Error'
      setTimeout(() => {
        addToCartBtn.textContent = 'Añadir al carrito'
        addToCartBtn.disabled = false
      }, 2000)
    }
  })
</script>
