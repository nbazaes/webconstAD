---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getApiOrigin } from '../../lib/api-origin'

export const prerender = false

const { slug = '' } = Astro.params
const apiOrigin = getApiOrigin(Astro)
const apiBase = new URL('/api/', apiOrigin)
let categoriaNombre = 'Categoria'

try {
  const res = await fetch(new URL(`categorias/${slug}/productos/`, apiBase))
  if (res.ok) {
    const data = await res.json()
    categoriaNombre = data.categoria?.nombre || categoriaNombre
  }
} catch (e) {
  // fallback to the default title when the API is unavailable
}

const pageTitle = `${categoriaNombre} | Gratis | Constant Archivos Digitales`

---

<BaseLayout title={pageTitle} page="gratis">
  <main class="content">
    <section class="products-hero text-block" data-cat-header hidden>
      <div class="category-hero">
        <div class="category-hero__image" hidden>
          <img data-cat-image alt="" hidden />
        </div>
        <div class="category-hero__content">
          <h2 data-cat-title>Categoria</h2>
          <p class="lead" data-cat-description hidden></p>
        </div>
      </div>
    </section>

    <section class="products-grid" data-cat-products hidden></section>
    <section class="products-hero text-block" data-cat-empty hidden>
      <p>No hay productos en esta categoría todavía.</p>
    </section>
  </main>

  <div class="download-modal" data-download-modal hidden>
    <div class="download-modal__backdrop" data-close-modal></div>
    <div class="download-modal__panel" role="dialog" aria-modal="true" aria-labelledby="download-modal-title">
      <h3 id="download-modal-title">Descargar producto</h3>
      <p data-modal-message></p>
      <div class="download-modal__actions">
        <button type="button" class="btn btn-secondary" data-cancel-download>Cerrar</button>
        <button type="button" class="btn" data-confirm-download>Descargar</button>
      </div>
      <div data-guest-subscription hidden>
        <hr style="margin: 16px 0; border: 0; border-top: 1px solid #e8d8cc;" />
        <p><strong>¡Sígueme en Instagram para más!</strong> <a href="https://www.instagram.com/constantdesigns/" target="_blank" rel="noopener">@constantdesigns</a></p>
        <p style="margin-top: 12px;">¿Quieres recibir notificaciones? Escribe tu correo para recibir las noticias de los nuevos productos.</p>
        <div class="auth-form" style="gap: 8px;">
          <input type="email" placeholder="tu@email.com" data-newsletter-email />
          <button type="button" class="btn" data-newsletter-save>Guardar correo</button>
        </div>
        <p class="auth-message" data-newsletter-status style="margin-top: 8px;"></p>
      </div>
    </div>
  </div>

  <div class="zoom-modal" data-zoom-modal hidden>
    <div class="zoom-modal__backdrop" data-close-zoom></div>
    <div class="zoom-modal__panel" role="dialog" aria-modal="true" aria-label="Vista previa">
      <button type="button" class="zoom-modal__close" data-close-zoom aria-label="Cerrar">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <img data-zoom-image src="" alt="" />
    </div>
  </div>

  <div class="global-loading-modal" data-global-loading hidden>
    <div class="global-loading-modal__backdrop"></div>
    <div class="global-loading-modal__panel">
      <span class="loading-spinner" aria-hidden="true"></span>
      <p>Procesando...</p>
    </div>
  </div>
</BaseLayout>

<script>
  const titleNode = document.querySelector('[data-cat-title]')
  const headerNode = document.querySelector('[data-cat-header]')
  const descriptionNode = document.querySelector('[data-cat-description]')
  const categoryImage = document.querySelector('[data-cat-image]')
  const productsGrid = document.querySelector('[data-cat-products]')
  const emptyNode = document.querySelector('[data-cat-empty]')
  const wrappers = () => document.querySelectorAll('[data-admin-product]')
  const modal = document.querySelector('[data-download-modal]')
  const closeButtons = document.querySelectorAll('[data-close-modal], [data-cancel-download]')
  const confirmButton = document.querySelector('[data-confirm-download]')
  const message = document.querySelector('[data-modal-message]')
  const newsletterInput = document.querySelector('[data-newsletter-email]')
  const newsletterSave = document.querySelector('[data-newsletter-save]')
  const newsletterStatus = document.querySelector('[data-newsletter-status]')
  const guestSubscription = document.querySelector('[data-guest-subscription]')
  const globalLoading = document.querySelector('[data-global-loading]')
  const zoomModal = document.querySelector('[data-zoom-modal]')
  const zoomImage = zoomModal?.querySelector('[data-zoom-image]')

  const backendOrigin = window.location.origin
  const backendUrl = (path) => `${backendOrigin}${path}`
  let isGuestUser = true

  let selectedSlug = ''
  let selectedName = ''

  const openLoadingModal = (text = 'Procesando...') => {
    if (!globalLoading) return
    const p = globalLoading.querySelector('p')
    if (p) p.textContent = text
    globalLoading.removeAttribute('hidden')
  }

  const closeLoadingModal = () => globalLoading?.setAttribute('hidden', '')

  const closeModal = () => {
    if (!modal) return
    modal.setAttribute('hidden', '')
    selectedSlug = ''
    guestSubscription?.setAttribute('hidden', '')
    if (newsletterStatus) newsletterStatus.textContent = ''
    if (newsletterInput) newsletterInput.value = ''
  }

  closeButtons.forEach((button) => button.addEventListener('click', closeModal))

  confirmButton?.addEventListener('click', async () => {
    if (!selectedSlug) {
      closeModal()
      return
    }

    const link = document.createElement('a')
    link.href = backendUrl(`/api/productos/${selectedSlug}/download/`)
    link.rel = 'noopener'
    link.target = '_blank'
    document.body.appendChild(link)
    link.click()
    link.remove()

    if (message) {
      message.textContent = 'Producto descargado exitosamente.'
    }

    if (isGuestUser) {
      guestSubscription?.removeAttribute('hidden')
    }

  })

  const wireDownloadButtons = () => {
    if (!productsGrid) return
    productsGrid.querySelectorAll('.free-download-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        selectedSlug = btn.getAttribute('data-product-slug') || ''
        selectedName = btn.getAttribute('data-product-name') || 'este archivo'
        if (!message || !modal) return
        message.textContent = `Quieres descargar "${selectedName}"?`
        modal.removeAttribute('hidden')
      })
    })
  }

  const wireZoomImages = () => {
    if (!productsGrid) return
    productsGrid.querySelectorAll('.free-product-image-wrapper').forEach((wrapper) => {
      wrapper.addEventListener('click', () => {
        const img = wrapper.querySelector('img')
        if (!img || !zoomModal || !zoomImage) return
        zoomImage.src = img.src
        zoomImage.alt = img.alt
        zoomModal.removeAttribute('hidden')
        document.body.style.overflow = 'hidden'
      })
    })
  }

  const closeZoomModal = () => {
    if (!zoomModal) return
    zoomModal.setAttribute('hidden', '')
    document.body.style.overflow = ''
    if (zoomImage) zoomImage.src = ''
  }

  zoomModal?.querySelectorAll('[data-close-zoom]').forEach((el) => el.addEventListener('click', closeZoomModal))

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && zoomModal && !zoomModal.hasAttribute('hidden')) {
      closeZoomModal()
    }
  })

  newsletterSave?.addEventListener('click', async () => {
    const email = String(newsletterInput?.value || '').trim()
    if (!email) {
      if (newsletterStatus) {
        newsletterStatus.textContent = 'Ingresa un correo valido.'
        newsletterStatus.classList.add('error')
      }
      return
    }

    const payload = new URLSearchParams()
    payload.append('email', email)

    await fetch(backendUrl('/api/newsletter/suscribir/'), {
      method: 'POST',
      credentials: 'include',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
      },
      body: payload,
    })

    if (newsletterStatus) {
      newsletterStatus.textContent = 'Correo guardado. Gracias por suscribirte!'
      newsletterStatus.classList.remove('error')
    }
  })

  const ensureAdminUi = async () => {
    const response = await fetch(backendUrl('/api/auth/session/'), { credentials: 'include' })
    if (!response.ok) return false
    const data = await response.json()
    return Boolean(data.authenticated && (data.user?.rol === 'admin' || data.user?.rol === 'artista' || data.user?.is_staff || data.user?.is_superuser))
  }

  const createEditModal = async (product) => {
    const [catRes, colRes] = await Promise.all([
      fetch(backendUrl('/api/catalog/categorias/'), { credentials: 'include' }),
      fetch(backendUrl('/api/catalog/colecciones/'), { credentials: 'include' }),
    ])
    if (!catRes.ok || !colRes.ok) return
    const catData = await catRes.json()
    const colData = await colRes.json()
    const categorias = (catData.results || []).filter((c) => c.es_gratuita)
    const colecciones = colData.results || []

    const modalEdit = document.createElement('div')
    modalEdit.className = 'edit-modal'
    const backdrop = document.createElement('div')
    backdrop.className = 'edit-modal__backdrop'
    backdrop.setAttribute('data-close-edit', '')

    const panel = document.createElement('div')
    panel.className = 'edit-modal__panel'
    panel.setAttribute('role', 'dialog')
    panel.setAttribute('aria-modal', 'true')

    const heading = document.createElement('h3')
    heading.textContent = 'Editar producto'

    const editFormNode = document.createElement('form')
    editFormNode.className = 'auth-form'
    editFormNode.setAttribute('data-edit-form', '')

    const nombreLabel = document.createElement('label')
    nombreLabel.textContent = 'Nombre'
    const nombreInput = document.createElement('input')
    nombreInput.name = 'nombre'
    nombreInput.type = 'text'
    nombreInput.required = true
    nombreInput.value = product.nombre || ''

    const descripcionLabel = document.createElement('label')
    descripcionLabel.textContent = 'Descripcion'
    const descripcionTextarea = document.createElement('textarea')
    descripcionTextarea.name = 'descripcion'
    descripcionTextarea.rows = 3
    descripcionTextarea.value = product.descripcion || ''

    const imagenLabel = document.createElement('label')
    imagenLabel.textContent = 'Imagen preview (opcional)'
    const imagenInput = document.createElement('input')
    imagenInput.name = 'imagen'
    imagenInput.type = 'file'
    imagenInput.accept = 'image/*'

    const gratisLabel = document.createElement('label')
    gratisLabel.textContent = 'Es gratuito?'
    const gratisSelectField = document.createElement('select')
    gratisSelectField.name = 'es_gratuito'
    gratisSelectField.setAttribute('data-edit-gratis', '')
    ;['true', 'false'].forEach((value) => {
      const option = document.createElement('option')
      option.value = value
      option.textContent = value === 'true' ? 'Si' : 'No'
      if ((value === 'true') === Boolean(product.es_gratuito)) option.selected = true
      gratisSelectField.appendChild(option)
    })

    const categoriaWrapField = document.createElement('div')
    categoriaWrapField.setAttribute('data-edit-categoria-wrap', '')
    if (!product.es_gratuito) categoriaWrapField.hidden = true
    const categoriaLabel = document.createElement('label')
    categoriaLabel.textContent = 'Categoria'
    const categoriaFieldNew = document.createElement('select')
    categoriaFieldNew.name = 'categoria_id'
    const categoriaEmpty = document.createElement('option')
    categoriaEmpty.value = ''
    categoriaEmpty.textContent = 'Sin categoria'
    categoriaFieldNew.appendChild(categoriaEmpty)
    categorias.forEach((c) => {
      const option = document.createElement('option')
      option.value = String(c.id)
      option.textContent = c.nombre
      if (product.categoria_id === c.id) option.selected = true
      categoriaFieldNew.appendChild(option)
    })
    categoriaWrapField.append(categoriaLabel, categoriaFieldNew)

    const coleccionWrapField = document.createElement('div')
    coleccionWrapField.setAttribute('data-edit-coleccion-wrap', '')
    if (product.es_gratuito) coleccionWrapField.hidden = true
    const coleccionLabel = document.createElement('label')
    coleccionLabel.textContent = 'Coleccion'
    const coleccionFieldNew = document.createElement('select')
    coleccionFieldNew.name = 'coleccion_id'
    const coleccionEmpty = document.createElement('option')
    coleccionEmpty.value = ''
    coleccionEmpty.textContent = 'Sin coleccion'
    coleccionFieldNew.appendChild(coleccionEmpty)
    colecciones.forEach((c) => {
      const option = document.createElement('option')
      option.value = String(c.id)
      option.textContent = c.nombre
      if (product.coleccion_id === c.id) option.selected = true
      coleccionFieldNew.appendChild(option)
    })
    coleccionWrapField.append(coleccionLabel, coleccionFieldNew)

    const paginasLabel = document.createElement('label')
    paginasLabel.textContent = 'Paginas'
    const paginasInput = document.createElement('input')
    paginasInput.name = 'paginas'
    paginasInput.type = 'number'
    paginasInput.min = '1'
    paginasInput.step = '1'
    paginasInput.value = product.paginas || ''

    const precioWrapField = document.createElement('div')
    precioWrapField.setAttribute('data-edit-precio-wrap', '')
    if (product.es_gratuito) precioWrapField.hidden = true
    const precioLabel = document.createElement('label')
    precioLabel.textContent = 'Precio'
    const precioInputField = document.createElement('input')
    precioInputField.name = 'precio'
    precioInputField.type = 'number'
    precioInputField.min = '0'
    precioInputField.step = '1'
    precioInputField.value = parseInt(product.precio) || ''
    precioWrapField.append(precioLabel, precioInputField)

    const activoLabel = document.createElement('label')
    activoLabel.textContent = 'Activo?'
    const activoSelectField = document.createElement('select')
    activoSelectField.name = 'activo'
    ;['true', 'false'].forEach((value) => {
      const option = document.createElement('option')
      option.value = value
      option.textContent = value === 'true' ? 'Si' : 'No'
      if ((value === 'true') === Boolean(product.activo)) option.selected = true
      activoSelectField.appendChild(option)
    })

    const actions = document.createElement('div')
    actions.className = 'published-actions'

    const submitButton = document.createElement('button')
    submitButton.className = 'btn'
    submitButton.type = 'submit'
    submitButton.textContent = 'Guardar'

    const cancelButton = document.createElement('button')
    cancelButton.className = 'btn btn-secondary'
    cancelButton.type = 'button'
    cancelButton.setAttribute('data-close-edit', '')
    cancelButton.textContent = 'Cancelar'

    actions.append(submitButton, cancelButton)

    editFormNode.append(
      nombreLabel,
      nombreInput,
      descripcionLabel,
      descripcionTextarea,
      imagenLabel,
      imagenInput,
      gratisLabel,
      gratisSelectField,
      categoriaWrapField,
      coleccionWrapField,
      paginasLabel,
      paginasInput,
      precioWrapField,
      activoLabel,
      activoSelectField,
      actions
    )

    panel.append(heading, editFormNode)
    modalEdit.append(backdrop, panel)
    document.body.appendChild(modalEdit)
    modalEdit.querySelectorAll('[data-close-edit]').forEach((el) => el.addEventListener('click', () => modalEdit.remove()))

    const gratisSelect = modalEdit.querySelector('[data-edit-gratis]')
    const categoriaWrap = modalEdit.querySelector('[data-edit-categoria-wrap]')
    const coleccionWrap = modalEdit.querySelector('[data-edit-coleccion-wrap]')
    const precioWrap = modalEdit.querySelector('[data-edit-precio-wrap]')
    const categoriaField = modalEdit.querySelector('select[name="categoria_id"]')
    const coleccionField = modalEdit.querySelector('select[name="coleccion_id"]')
    const precioField = modalEdit.querySelector('input[name="precio"]')

    const applyEditRules = () => {
      const isFree = gratisSelect?.value === 'true'
      if (categoriaWrap) categoriaWrap.hidden = !isFree
      if (coleccionWrap) coleccionWrap.hidden = isFree
      if (precioWrap) precioWrap.hidden = isFree
      if (categoriaField) categoriaField.disabled = !isFree
      if (coleccionField) coleccionField.disabled = isFree
      if (precioField) precioField.disabled = isFree
      if (isFree) {
        if (coleccionField) coleccionField.value = ''
        if (precioField) precioField.value = ''
      } else if (categoriaField) {
        categoriaField.value = ''
      }
    }
    gratisSelect?.addEventListener('change', applyEditRules)
    applyEditRules()

    const editForm = modalEdit.querySelector('[data-edit-form]')
    editForm?.addEventListener('submit', async (event) => {
      event.preventDefault()
      const ok = await (window.showStyledConfirm
        ? window.showStyledConfirm(`¿Confirmas guardar cambios en ${product.nombre}?`)
        : Promise.resolve(confirm(`¿Confirmas guardar cambios en ${product.nombre}?`)))
      if (!ok) return

      const formData = new FormData(editForm)
      openLoadingModal('Guardando cambios...')
      const response = await fetch(backendUrl(`/api/admin/productos/${product.id}/editar/`), {
        method: 'POST',
        credentials: 'include',
        body: formData,
      })
      closeLoadingModal()
      if (!response.ok) return
      window.location.reload()
    })
  }

  ensureAdminUi().then((isAdmin) => {
    if (!isAdmin) {
      document.querySelectorAll('[data-admin-actions]').forEach((actions) => actions.setAttribute('hidden', ''))
      return
    }

    document.querySelectorAll('[data-admin-actions]').forEach((actions) => actions.removeAttribute('hidden'))

    wrappers().forEach((wrapper) => {
      const product = {
        id: Number(wrapper.getAttribute('data-product-id') || 0),
        nombre: wrapper.dataset.productNombre || '',
        descripcion: wrapper.dataset.productDescripcion || '',
      }

      wrapper.querySelector('[data-delete-product]')?.addEventListener('click', async () => {
        const ok = await (window.showStyledConfirm
          ? window.showStyledConfirm(`¿Confirmas eliminar ${product.nombre}?`)
          : Promise.resolve(confirm(`¿Confirmas eliminar ${product.nombre}?`)))
        if (!ok) return

        openLoadingModal('Eliminando producto...')
        const response = await fetch(backendUrl(`/api/admin/productos/${product.id}/eliminar/`), {
          method: 'POST',
          credentials: 'include',
        })
        closeLoadingModal()
        if (!response.ok) return
        window.location.reload()
      })

      wrapper.querySelector('[data-edit-product]')?.addEventListener('click', () => createEditModal(product))
    })
  })

  fetch(backendUrl('/api/auth/session/'), { credentials: 'include' }).then(async (response) => {
    if (!response.ok) return
    const data = await response.json()
    isGuestUser = !data.authenticated
  })

  const renderProducts = (products) => {
    if (!productsGrid) return
    if (!products.length) {
      emptyNode?.removeAttribute('hidden')
      productsGrid.setAttribute('hidden', '')
      return
    }

    productsGrid.replaceChildren()

    products.forEach((producto) => {
      const article = document.createElement('article')
      article.className = 'free-product-wrap'
      article.setAttribute('data-admin-product', '')
      article.setAttribute('data-product-id', String(producto.id))
      article.dataset.productNombre = producto.nombre || ''
      article.dataset.productDescripcion = producto.descripcion || ''

      const imageWrapper = document.createElement('div')
      imageWrapper.className = 'free-product-image-wrapper'
      imageWrapper.title = producto.descripcion || producto.nombre || ''

      const img = document.createElement('img')
      img.src = producto.imagen || '/static/web/assets/g345.webp'
      img.alt = producto.descripcion || producto.nombre || ''
      img.title = producto.descripcion || producto.nombre || ''
      img.width = 220
      img.height = 220
      if (producto.imagen) img.loading = 'lazy'

      const overlay = document.createElement('div')
      overlay.className = 'zoom-overlay'
      overlay.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>'

      imageWrapper.append(img, overlay)

      const name = document.createElement('span')
      name.className = 'product-name'
      name.title = producto.descripcion || producto.nombre || ''
      name.textContent = producto.nombre || ''

      const downloadBtn = document.createElement('button')
      downloadBtn.type = 'button'
      downloadBtn.className = 'btn free-download-btn'
      downloadBtn.setAttribute('data-product-slug', producto.slug || '')
      downloadBtn.setAttribute('data-product-name', producto.nombre || '')
      downloadBtn.textContent = 'Descargar'

      article.append(imageWrapper, name, downloadBtn)

      const actions = document.createElement('div')
      actions.className = 'published-actions'
      actions.setAttribute('data-admin-actions', '')
      actions.hidden = true

      const editButton = document.createElement('button')
      editButton.className = 'btn'
      editButton.type = 'button'
      editButton.setAttribute('data-edit-product', '')
      editButton.textContent = 'Editar'

      const deleteButton = document.createElement('button')
      deleteButton.className = 'btn btn-secondary'
      deleteButton.type = 'button'
      deleteButton.setAttribute('data-delete-product', '')
      deleteButton.textContent = 'Eliminar'

      actions.append(editButton, deleteButton)
      article.appendChild(actions)
      productsGrid.appendChild(article)
    })

    productsGrid.removeAttribute('hidden')
    wireDownloadButtons()
    wireZoomImages()
    ensureAdminUi().then((isAdmin) => {
      if (!isAdmin) return
      document.querySelectorAll('[data-admin-actions]').forEach((actions) => actions.removeAttribute('hidden'))
    })
  }

  const initCategory = async () => {
    const pathParts = window.location.pathname.split('/').filter(Boolean)
    const slug = pathParts.length ? pathParts[pathParts.length - 1] : ''
    if (!slug) {
      emptyNode?.removeAttribute('hidden')
      return
    }

    const response = await fetch(backendUrl(`/api/categorias/${slug}/productos/`), { credentials: 'include' })
    if (!response.ok) {
      emptyNode?.removeAttribute('hidden')
      return
    }

    const data = await response.json()
    const categoria = data.categoria || {}
    if (titleNode) titleNode.textContent = categoria.nombre || 'Categoria'
    if (categoria.descripcion && descriptionNode) {
      descriptionNode.textContent = categoria.descripcion
      descriptionNode.removeAttribute('hidden')
    }
    if (categoria.imagen && categoryImage) {
      categoryImage.src = categoria.imagen
      categoryImage.alt = categoria.descripcion || categoria.nombre || 'Categoria'
      categoryImage.width = 320
      categoryImage.height = 245
      categoryImage.setAttribute('hidden', '')
    }
    headerNode?.removeAttribute('hidden')

    renderProducts(data.results || [])
  }

  initCategory()
</script>

<style is:global>
  .free-product-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
  }

  .category-hero {
    display: grid;
    grid-template-columns: minmax(0, 320px) minmax(0, 1fr);
    gap: 28px;
    align-items: center;
  }

  .category-hero__image {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .category-hero__image img {
    width: 100%;
    max-width: 320px;
    height: auto;
    object-fit: contain;
  }

  .free-product-image-wrapper {
    position: relative;
    cursor: zoom-in;
    border-radius: 6px;
    overflow: hidden;
    line-height: 0;
  }

  .free-product-image-wrapper img {
    width: 220px;
    height: auto;
    object-fit: contain;
    border-radius: 6px;
    box-shadow: none;
    background: #fff;
    transition: box-shadow 0.2s ease, transform 0.2s ease, filter 0.25s ease;
    display: block;
  }

  .free-product-image-wrapper:hover img {
    transform: translateY(-3px);
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.12);
    filter: blur(3px);
  }

  .free-product-image-wrapper:focus-visible img {
    transform: translateY(-3px);
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.12);
    filter: blur(3px);
  }

  .zoom-overlay {
    position: absolute;
    inset: 0;
    display: grid;
