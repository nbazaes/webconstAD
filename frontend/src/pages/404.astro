---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Página no encontrada | Constant Archivos Digitales" page="404">
  <main class="content">
    <section class="products-hero text-block" style="text-align: center; padding-top: 60px;">
      <h2 style="font-size: 120px; margin: 0; line-height: 1; color: #243233;">404</h2>
      <h2 style="margin-top: 20px;">Página no encontrada</h2>
      <p class="lead">
        Lo sentimos, la página que buscas <em>no existe</em> o ha sido movida.
      </p>
      <p style="margin-top: 30px;">
        <a href="/" class="btn">Volver al inicio</a>
      </p>
    </section>
  </main>
</BaseLayout>
