---
import BaseLayout from '../layouts/BaseLayout.astro'
import { Icon } from 'astro-icon/components'

const apiOrigin = import.meta.env.BUILD_API_ORIGIN || import.meta.env.API_ORIGIN || 'http://127.0.0.1:8000'

let productos = []
let categorias = []

try {
  const [prodRes, catRes] = await Promise.all([
    fetch(`${apiOrigin}/api/productos/`),
    fetch(`${apiOrigin}/api/categorias/`),
  ])
  if (prodRes.ok) {
    const data = await prodRes.json()
    productos = (data.results || []).filter(p => !p.es_gratuito && p.coleccion)
  }
  if (catRes.ok) {
    const data = await catRes.json()
    categorias = data.results || []
  }
} catch {}

const featuredProducts = productos.slice(0, 4)

const trendingCategories = [...categorias].sort(() => Math.random() - 0.5).slice(0, 4)

const freeCategories = categorias.filter(c => c.imagen).slice(0, 2)
---

<BaseLayout title="Inicio | Constant Archivos Digitales" page="inicio">
  <main>
    <!-- ========== 1. HERO ========== -->
    <section class="hero" aria-label="Presentación">
      <div class="hero-content">
        <h1 class="hero-title">
          Archivos digitales para <em>imprimir</em> o <em>dibujar</em>
        </h1>
        <p class="hero-description">
          Descarga diseños originales de Jenny Constant — cuadernas, libretas, novelas gráficas y más, listos para dar vida a tus proyectos.
        </p>
        <div class="hero-cta">
          <a href="/productos/" class="btn">Ver productos</a>
          <a href="/gratis/" class="btn-outline">Explorar gratis</a>
        </div>
      </div>
      <div class="hero-visual">
        <img src="/static/web/assets/path63.svg" alt="" class="hero-decor" aria-hidden="true" loading="lazy" />
        <img src="/static/web/assets/hero1.webp" alt="Muestra de cuaderna ilustrada" class="hero-img-main" width="540" height="360" fetchpriority="high" />
        <img src="/static/web/assets/hero2.webp" alt="Muestra de libreta digital" class="hero-img-secondary" width="547" height="360" loading="lazy" />
      </div>
    </section>

    <!-- ========== 2. CÓMO FUNCIONA ========== -->
    <section class="landing-section" aria-labelledby="how-title">
      <div class="section-header">
        <h2 id="how-title" class="section-title">Cómo funciona</h2>
        <p class="section-subtitle">Tres pasos simples para empezar</p>
      </div>
      <div class="steps">
        <article class="step-card">
          <Icon name="lucide:search" class="step-icon" />
          <h3>Elige tu diseño</h3>
          <p>Explora nuestra colección de cuadernas, libretas y novelas gráficas. Filtra por categoría y encuentra el estilo que buscas.</p>
        </article>
        <article class="step-card">
          <Icon name="lucide:credit-card" class="step-icon" />
          <h3>Compra seguro</h3>
          <p>Paga por transferencia bancaria de forma segura. Una vez confirmado, recibirás el enlace de descarga al instante.</p>
        </article>
        <article class="step-card">
          <Icon name="lucide:download" class="step-icon" />
          <h3>Descarga y crea</h3>
          <p>Imprime en casa o dibuja digitalmente. Todos los archivos vienen en alta resolución listos para usar.</p>
        </article>
      </div>
    </section>

    <!-- ========== 3. CATEGORÍAS DESTACADAS ========== -->
    <section class="landing-section" aria-labelledby="categories-title">
      <div class="section-header">
        <h2 id="categories-title" class="section-title">Categorías destacadas</h2>
        <p class="section-subtitle">Descubre los tipos de archivos que ofrecemos</p>
      </div>
      {trendingCategories.length > 0 ? (
        <div class="categories-grid" data-categories-grid>
          {trendingCategories.map((cat) => (
            <a href={`/gratis/${cat.slug}/`} class="category-card" data-category-id={cat.id}>
              {cat.imagen ? (
                <img src={cat.imagen} alt={cat.nombre} loading="lazy" />
              ) : (
                <div style="position:absolute;inset:0;background:var(--accent)"></div>
              )}
              <div class="category-card-overlay">
                <h3>{cat.nombre}</h3>
                {cat.descripcion && <span>{cat.descripcion}</span>}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p style="text-align:center;color:#8a7f75;">Categorías próximamente</p>
      )}
    </section>

    <!-- ========== 4. PRODUCTOS DESTACADOS ========== -->
    {featuredProducts.length > 0 && (
      <section class="landing-section" aria-labelledby="featured-title">
        <div class="section-header">
          <h2 id="featured-title" class="section-title">Productos destacados</h2>
          <p class="section-subtitle">Los favoritos de nuestra colección</p>
        </div>
        <div class="featured-grid" data-featured-grid>
          {featuredProducts.map((p) => (
            <article class="featured-card" data-product-id={p.id}>
              <a href={`/productos/${p.slug}/`} class="featured-card-img">
                {p.imagen ? (
                  <img src={p.imagen} alt={p.nombre} loading="lazy" />
                ) : (
                  <div style="width:100%;height:100%;display:grid;place-items:center;color:#8a7f75;font-size:14px;">Sin imagen</div>
                )}
              </a>
              <div class="featured-card-body">
                <h3><a href={`/productos/${p.slug}/`} style="color:inherit;text-decoration:none;">{p.nombre}</a></h3>
                <span class="featured-card-price">${String(p.precio).replace(/\B(?=(\d{3})+(?!\d))/g, ' ')}</span>
                <a href={`/productos/${p.slug}/`} class="btn">Ver producto</a>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- ========== 5. DESCARGAS GRATIS ========== -->
    <section class="landing-section" aria-labelledby="free-title">
      <div class="section-header">
        <h2 id="free-title" class="section-title">Archivos gratuitos</h2>
        <p class="section-subtitle">Descarga muestras y diseños gratis para probar</p>
      </div>
      {freeCategories.length > 0 ? (
        <div class="free-grid">
          {freeCategories.map((cat) => (
            <a href={`/gratis/${cat.slug}/`} class="free-card">
              {cat.imagen ? (
                <img src={cat.imagen} alt={cat.nombre} loading="lazy" />
              ) : (
                <div style="position:absolute;inset:0;background:var(--accent)"></div>
              )}
              <div class="free-card-overlay">
                <h3>{cat.nombre}</h3>
                {cat.descripcion && <p>{cat.descripcion}</p>}
              </div>
            </a>
          ))}
          <a href="/gratis/" class="free-card" style="background:var(--muted);display:flex;align-items:center;justify-content:center;">
            <div style="text-align:center;color:#243233;padding:20px;position:relative;z-index:1;">
              <Icon name="lucide:arrow-right" style="width:32px;height:32px;margin-bottom:8px;" />
              <h3 style="font-family:'Playfair Display',Georgia,serif;margin:0;font-size:20px;">Ver todos los gratis</h3>
            </div>
          </a>
        </div>
      ) : (
        <div style="text-align:center;">
          <a href="/gratis/" class="btn" style="font-size:17px;padding:14px 32px;">Explorar archivos gratis</a>
        </div>
      )}
    </section>

    <!-- ========== 6. TESTIMONIOS ========== -->
    <section class="landing-section" aria-labelledby="testimonials-title" data-testimonials-section>
      <div class="section-header">
        <h2 id="testimonials-title" class="section-title">Lo que dicen nuestros clientes</h2>
        <p class="section-subtitle">Reseñas de quienes ya descargaron nuestros diseños</p>
      </div>
      <div class="testimonials-grid" data-testimonials-grid>
        <article class="testimonial-card" data-testimonial>
          <div class="testimonial-stars" aria-label="5 estrellas">★★★★★</div>
          <p class="testimonial-text" data-testimonial-text>"Los diseños son hermosos y la calidad de impresión es increíble. Compro regularmente para mis proyectos de lettering."</p>
          <footer class="testimonial-author">
            <div class="testimonial-avatar" data-testimonial-avatar>JD</div>
            <div>
              <div class="testimonial-name" data-testimonial-name>María González</div>
              <div class="testimonial-role" data-testimonial-role>Diseñadora gráfica</div>
            </div>
          </footer>
        </article>
        <article class="testimonial-card" data-testimonial>
          <div class="testimonial-stars" aria-label="5 estrellas">★★★★★</div>
          <p class="testimonial-text" data-testimonial-text>"Me encanta la variedad de cuadernas que tienen. Compré la colección de naturaleza y los resultados son espectaculares."</p>
          <footer class="testimonial-author">
            <div class="testimonial-avatar" data-testimonial-avatar>CP</div>
            <div>
              <div class="testimonial-name" data-testimonial-name>Carlos Palma</div>
              <div class="testimonial-role" data-testimonial-role>Ilustrador</div>
            </div>
          </footer>
        </article>
        <article class="testimonial-card" data-testimonial>
          <div class="testimonial-stars" aria-label="5 estrellas">★★★★★</div>
          <p class="testimonial-text" data-testimonial-text>"Descargué varios archivos gratis y quedé tan contento que terminé comprando la colección completa. Muy recomendado."</p>
          <footer class="testimonial-author">
            <div class="testimonial-avatar" data-testimonial-avatar>AL</div>
            <div>
              <div class="testimonial-name" data-testimonial-name>Andrea López</div>
              <div class="testimonial-role" data-testimonial-role>Aficionada al lettering</div>
            </div>
          </footer>
        </article>
      </div>
    </section>

    <!-- ========== 7. PRESENTACIÓN DE LA ARTISTA ========== -->
    <section class="landing-section" aria-labelledby="artist-title">
      <div class="artist-section" itemscope itemtype="https://schema.org/Person">
        <div class="artist-avatar-wrap">
          <img src="/static/web/assets/logo.webp" alt="Jenny Constant" class="artist-avatar" width="180" height="180" loading="lazy" itemprop="image" />
        </div>
        <div class="artist-info">
          <span class="artist-brand">Constant Designs</span>
          <h2 id="artist-title" class="artist-name" itemprop="name">Jenny Constant</h2>
          <p class="artist-bio" itemprop="description">
            Diseñadora apasionada por la ilustración digital y el lettering. Creadora de Constant Designs, donde cada archivo está pensado para inspirar tu creatividad. Con años de experiencia en diseño gráfico, Jenny transforma ideas en piezas únicas listas para imprimir o dibujar.
          </p>
          <div class="artist-social">
            <a href="https://www.instagram.com/constantdesigns" target="_blank" rel="noreferrer" aria-label="Instagram de Constant Designs">
              <Icon name="lucide:instagram" width="20" height="20" />
              @constantdesigns
            </a>
            <a href="https://github.com/nbazaes" target="_blank" rel="noreferrer" aria-label="GitHub">
              <Icon name="lucide:github" width="20" height="20" />
              nbazaes
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ========== 8. CTA FINAL ========== -->
    <section class="cta-banner" aria-labelledby="cta-title">
      <img src="/static/web/assets/g40.svg" alt="" class="cta-banner-decor" aria-hidden="true" loading="lazy" />
      <h2 id="cta-title" class="cta-banner-title">¿Listo para empezar?</h2>
      <p>Elige entre nuestra colección de archivos digitales y dale vida a tu próximo proyecto.</p>
      <a href="/productos/" class="btn">Ver productos</a>
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    animation: none;
  }
  .hero > * {
    animation: fade-rise 0.7s ease both;
  }
  .hero > *:nth-child(1) { animation-delay: 0ms; }
  .hero > *:nth-child(2) { animation-delay: 120ms; }

  .landing-section > * {
    animation: fade-rise 0.7s ease both;
  }
  .landing-section > *:nth-child(1) { animation-delay: 0ms; }
  .landing-section > *:nth-child(2) { animation-delay: 80ms; }
</style>
