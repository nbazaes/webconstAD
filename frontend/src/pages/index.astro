---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Inicio | Constant Archivos Digitales" page="inicio">
  <main class="content">
    <h2 class="subtitle">Archivos para <em>imprimir</em> o <em>dibujar</em> digitalmente.</h2>

    <section class="showcase">
      <article class="card">
        <img src="/static/web/assets/hero1.webp" alt="Muestra principal 1" width="540" height="360" style="aspect-ratio:540/360" fetchpriority="high"
          srcset="/static/web/assets/hero1-350.webp 350w, /static/web/assets/hero1.webp 540w"
          sizes="(max-width: 700px) 100vw, (max-width: 1000px) 50vw, 540px" />
      </article>
      <img src="/static/web/assets/path63.svg" alt="" class="decor-dots" aria-hidden="true" width="200" height="193" loading="lazy" />
      <article class="card"> <img src="/static/web/assets/hero2.webp" alt="Muestra principal 2" width="547" height="360" style="aspect-ratio:547/360" loading="lazy"
          srcset="/static/web/assets/hero2-350.webp 350w, /static/web/assets/hero2.webp 547w"
          sizes="(max-width: 700px) 100vw, (max-width: 1000px) 50vw, 547px" /> </article>
    </section>
  </main>
</BaseLayout>
