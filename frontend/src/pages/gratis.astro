---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getApiOrigin } from '../lib/api-origin'

export const prerender = false

const apiOrigin = getApiOrigin(Astro)

let categorias = []
let categoriasCatalogo = []
try {
  const apiBase = new URL('/api/', apiOrigin)
  const respuesta = await fetch(new URL('categorias/', apiBase))
  const datos = await respuesta.json()
  categorias = datos.results || []

  const catalogRes = await fetch(new URL('catalog/categorias/', apiBase))
  const catalogData = await catalogRes.json()
  categoriasCatalogo = catalogData.results || []
} catch (e) {
  // API may not be available during build; use empty data
}

const categoriasConImagen = new Map(categorias.map((item) => [item.slug, item]))
const categoriasRender = [...categoriasCatalogo]
  .sort((a, b) => Number(b.es_gratuita) - Number(a.es_gratuita) || a.nombre.localeCompare(b.nombre, 'es'))
  .map((item) => {
    const fromList = categoriasConImagen.get(item.slug)
    return {
      ...item,
      descripcion: fromList?.descripcion || '',
      imagen: fromList?.imagen || null,
    }
  })
---

<BaseLayout title="Gratis | Constant Archivos Digitales" page="gratis">
  <main class="content">
    <section class="products-hero text-block">
      <h2>GRATIS</h2>
<p class="lead">Recursos gratuitos para <em>imprimir</em> o <em>dibujar</em> digitalmente.</p>
    </section>

    <div class="catalog-cta-wrapper" data-catalog-cta hidden>
      <div class="catalog-cta">
        <h3>Agregar categoría</h3>
        <p>Crea una nueva categoría gratuita desde aquí.</p>
        <div class="catalog-cta__actions">
          <button class="btn" type="button" data-open-add-categoria>Crear categoría</button>
          <a class="btn btn-secondary" href="/publicar/">Ir a publicar</a>
        </div>
        <div class="catalog-cta__helper">Disponible para admins y artistas.</div>
      </div>
    </div>

    <section class="products-grid" data-free-categories hidden={categoriasRender.length === 0}>
      {categoriasRender.length > 0 ? (
        <>
        {categoriasRender.map((cat) => (
          <div class="product">
            <a href={`/gratis/${cat.slug}/`} class="product-link" title={cat.descripcion || ''}>
              {cat.imagen ? (
                <img
                  src={cat.imagen}
                  alt={cat.descripcion || cat.nombre}
                  width="286"
                  height="372"
                  loading="lazy"
                />
              ) : (
                <div class="card">
                  <img src="/static/web/assets/g345.webp" alt="Sin imagen" width="190" height="89" />
                </div>
              )}
            </a>
            <a href={`/gratis/${cat.slug}/`} class="product-title" title={cat.descripcion || ''}>
              {cat.nombre}
            </a>
            <div class="published-actions" data-admin-actions hidden>
              <button class="btn" type="button" data-edit-categoria={cat.id}>Editar</button>
              <button class="btn btn-secondary" type="button" data-delete-categoria={cat.id}>Eliminar</button>
            </div>
          </div>
        ))}
        </>
      ) : null}
    </section>

    <section class="products-hero text-block" data-free-empty hidden={categoriasRender.length > 0}>
      <p>Próximamente recursos gratuitos.</p>
      <ul>
        <li>Plantillas de práctica</li>
        <li>Mini colecciones de muestra</li>
        <li>Recursos estacionales</li>
      </ul>
    </section>

    <div class="global-loading-modal" data-global-loading hidden>
      <div class="global-loading-modal__backdrop"></div>
      <div class="global-loading-modal__panel">
        <span class="loading-spinner" aria-hidden="true"></span>
        <p>Procesando...</p>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .product-link {
    display: block;
    text-decoration: none;
    width: 286px;
    height: 372px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .product-link img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 6px;
    box-shadow: none;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .product-link:hover img,
  .product-link:focus-visible img,
  .product-link:active img {
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.12);
    transform: translateY(-3px);
  }
  .product-title {
    display: block;
    margin-top: 12px;
    color: #111;
    text-decoration: none;
    font-family: 'PT Serif', serif;
    font-weight: 600;
    font-size: 1.2rem;
  }
  .product-title span {
    display: block;
    font-weight: 400;
    color: #333;
    font-size: 1rem;
  }

  .catalog-cta {
    border: 1px dashed #d9cfc6;
    border-radius: 12px;
    background: #fffaf5;
    padding: 18px;
    display: grid;
    gap: 12px;
    text-align: center;
    align-content: center;
    min-height: 210px;
    width: 100%;
    box-sizing: border-box;
    font-size: 1rem;
  }

  .catalog-cta h3 {
    margin: 0;
    font-size: 1.2rem;
  }

  .catalog-cta p {
    margin: 0;
    color: #5b4f46;
  }

  .catalog-cta__actions {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .catalog-cta__actions .btn {
    white-space: nowrap;
  }

  .catalog-cta__helper {
    font-size: 0.95rem;
    color: #6d6158;
  }

  .catalog-cta-wrapper {
    max-width: 1100px;
    margin: 0 auto 28px;
    padding: 0 20px 80px;
  }

  @media (max-width: 720px) {
    .products-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
      padding: 0 8px;
    }

    .product-link {
      width: 150px;
      height: 195px;
    }

    .product-title {
      font-size: 1rem;
      margin-top: 8px;
    }

    .catalog-cta-wrapper {
      padding: 0 8px 64px;
    }

    .catalog-cta {
      padding: 14px;
      min-height: 160px;
    }

    .catalog-cta__actions {
      gap: 16px;
    }
  }
</style>

<script>
  const backendOrigin = window.location.origin
  const backendUrl = (path) => `${backendOrigin}${path}`
  const grid = document.querySelector('[data-free-categories]')

  const openLoadingModal = (text = 'Procesando...') => {
    const el = document.querySelector('[data-global-loading]')
    if (!el) return
    const p = el.querySelector('p')
    if (p) p.textContent = text
    el.removeAttribute('hidden')
  }

  const closeLoadingModal = () => {
    const el = document.querySelector('[data-global-loading]')
    el?.setAttribute('hidden', '')
  }
  const emptyBlock = document.querySelector('[data-free-empty]')

  const canManageCatalog = (data) =>
    Boolean(
      data?.authenticated &&
        (data.user?.rol === 'admin' || data.user?.rol === 'artista' || data.user?.is_staff || data.user?.is_superuser)
    )

  const ctaBlock = document.querySelector('[data-catalog-cta]')

  const showAdminCta = () => {
    if (!ctaBlock || ctaBlock.hasAttribute('shown')) return
    ctaBlock.removeAttribute('hidden')
    ctaBlock.setAttribute('shown', '')
    ctaBlock.querySelector('[data-open-add-categoria]')?.addEventListener('click', openCatalogModal)
  }

  const openCatalogModal = async () => {
    const modal = document.createElement('div')
    modal.className = 'catalog-modal'
    const backdrop = document.createElement('div')
    backdrop.className = 'catalog-modal__backdrop'
    backdrop.setAttribute('data-close-catalog', '')

    const panel = document.createElement('div')
    panel.className = 'catalog-modal__panel'
    panel.setAttribute('role', 'dialog')
    panel.setAttribute('aria-modal', 'true')

    const heading = document.createElement('h3')
    heading.textContent = 'Nueva categoría gratis'

    const form = document.createElement('form')
    form.className = 'auth-form'
    form.setAttribute('data-catalog-form', '')

    const tipoInput = document.createElement('input')
    tipoInput.type = 'hidden'
    tipoInput.name = 'tipo'
    tipoInput.value = 'categoria'

    const nombreLabel = document.createElement('label')
    nombreLabel.textContent = 'Nombre'
    const nombreInput = document.createElement('input')
    nombreInput.name = 'nombre'
    nombreInput.type = 'text'
    nombreInput.required = true

    const descripcionLabel = document.createElement('label')
    descripcionLabel.textContent = 'Descripción'
    const descripcionTextarea = document.createElement('textarea')
    descripcionTextarea.name = 'descripcion'
    descripcionTextarea.rows = 3

    const imagenLabel = document.createElement('label')
    imagenLabel.textContent = 'Imagen (opcional)'
    const imagenInput = document.createElement('input')
    imagenInput.name = 'imagen'
    imagenInput.type = 'file'
    imagenInput.accept = 'image/*'

    const gratuitaInput = document.createElement('input')
    gratuitaInput.type = 'hidden'
    gratuitaInput.name = 'es_gratuita'
    gratuitaInput.value = 'true'

    const actions = document.createElement('div')
    actions.className = 'published-actions'

    const submitButton = document.createElement('button')
    submitButton.className = 'btn'
    submitButton.type = 'submit'
    submitButton.textContent = 'Crear'

    const cancelButton = document.createElement('button')
    cancelButton.className = 'btn btn-secondary'
    cancelButton.type = 'button'
    cancelButton.setAttribute('data-close-catalog', '')
    cancelButton.textContent = 'Cancelar'

    actions.append(submitButton, cancelButton)

    const message = document.createElement('p')
    message.className = 'auth-message'
    message.setAttribute('data-catalog-message', '')

    form.append(
      tipoInput,
      nombreLabel,
      nombreInput,
      descripcionLabel,
      descripcionTextarea,
      imagenLabel,
      imagenInput,
      gratuitaInput,
      actions
    )

    panel.append(heading, form, message)
    modal.append(backdrop, panel)

    document.body.appendChild(modal)
    const close = () => modal.remove()
    modal.querySelectorAll('[data-close-catalog]').forEach((el) => el.addEventListener('click', close))

    const catalogForm = modal.querySelector('[data-catalog-form]')
    const catalogMessage = modal.querySelector('[data-catalog-message]')
    catalogForm?.addEventListener('submit', async (event) => {
      event.preventDefault()
      if (catalogMessage) catalogMessage.textContent = ''

      const formData = new FormData(catalogForm)
      formData.set('es_gratuita', 'true')
      const nombre = String(formData.get('nombre') || '').trim()
      if (!nombre) {
        if (catalogMessage) catalogMessage.textContent = 'Nombre es obligatorio.'
        return
      }

      const ok = await (window.showStyledConfirm
        ? window.showStyledConfirm(`¿Crear la categoría "${nombre}"?`)
        : Promise.resolve(confirm(`¿Crear la categoría "${nombre}"?`)))
      if (!ok) return

      openLoadingModal('Creando categoría...')
      try {
        const response = await fetch(backendUrl('/api/admin/catalogo/crear/'), {
          method: 'POST',
          credentials: 'include',
          body: formData,
        })
        const data = await response.json().catch(() => ({}))
        if (!response.ok || !data.ok) {
          if (catalogMessage) catalogMessage.textContent = data.message || 'No se pudo crear la categoría.'
          return
        }

        close()
        window.location.reload()
      } finally {
        closeLoadingModal()
      }
    })
  }

  const openEditCategoriaModal = (id, nombre, descripcion) => {
    const modal = document.createElement('div')
    modal.className = 'catalog-modal'
    const backdrop = document.createElement('div')
    backdrop.className = 'catalog-modal__backdrop'
    backdrop.setAttribute('data-close-catalog', '')

    const panel = document.createElement('div')
    panel.className = 'catalog-modal__panel'
    panel.setAttribute('role', 'dialog')
    panel.setAttribute('aria-modal', 'true')

    const heading = document.createElement('h3')
    heading.textContent = 'Editar categoría'

    const form = document.createElement('form')
    form.className = 'auth-form'
    form.setAttribute('data-catalog-form', '')

    const tipoInput = document.createElement('input')
    tipoInput.type = 'hidden'
    tipoInput.name = 'tipo'
    tipoInput.value = 'categoria'

    const nombreLabel = document.createElement('label')
    nombreLabel.textContent = 'Nombre'
    const nombreInput = document.createElement('input')
    nombreInput.name = 'nombre'
    nombreInput.type = 'text'
    nombreInput.required = true
    nombreInput.value = nombre || ''

    const descripcionLabel = document.createElement('label')
    descripcionLabel.textContent = 'Descripción'
    const descripcionTextarea = document.createElement('textarea')
    descripcionTextarea.name = 'descripcion'
    descripcionTextarea.rows = 3
    descripcionTextarea.value = descripcion || ''

    const imagenLabel = document.createElement('label')
    imagenLabel.textContent = 'Imagen (opcional)'
    const imagenInput = document.createElement('input')
    imagenInput.name = 'imagen'
    imagenInput.type = 'file'
    imagenInput.accept = 'image/*'

    const gratuitaInput = document.createElement('input')
    gratuitaInput.type = 'hidden'
    gratuitaInput.name = 'es_gratuita'
    gratuitaInput.value = 'true'

    const actions = document.createElement('div')
    actions.className = 'published-actions'

    const submitButton = document.createElement('button')
    submitButton.className = 'btn'
    submitButton.type = 'submit'
    submitButton.textContent = 'Guardar'

    const cancelButton = document.createElement('button')
    cancelButton.className = 'btn btn-secondary'
    cancelButton.type = 'button'
    cancelButton.setAttribute('data-close-catalog', '')
    cancelButton.textContent = 'Cancelar'

    actions.append(submitButton, cancelButton)

    const message = document.createElement('p')
    message.className = 'auth-message'
    message.setAttribute('data-catalog-message', '')

    form.append(
      tipoInput,
      nombreLabel,
      nombreInput,
      descripcionLabel,
      descripcionTextarea,
      imagenLabel,
      imagenInput,
      gratuitaInput,
      actions
    )

    panel.append(heading, form, message)
    modal.append(backdrop, panel)

    document.body.appendChild(modal)
    const close = () => modal.remove()
    modal.querySelectorAll('[data-close-catalog]').forEach((el) => el.addEventListener('click', close))

    const catalogEditForm = modal.querySelector('[data-catalog-form]')
    const catalogEditMessage = modal.querySelector('[data-catalog-message]')
    catalogEditForm?.addEventListener('submit', async (event) => {
      event.preventDefault()
      if (catalogEditMessage) catalogEditMessage.textContent = ''

      const formData = new FormData(catalogEditForm)
      formData.set('es_gratuita', 'true')
      const nombreVal = String(formData.get('nombre') || '').trim()
      if (!nombreVal) {
        if (catalogEditMessage) catalogEditMessage.textContent = 'Nombre es obligatorio.'
        return
      }

      const ok = await (window.showStyledConfirm
        ? window.showStyledConfirm(`¿Guardar cambios en "${nombreVal}"?`)
        : Promise.resolve(confirm(`¿Guardar cambios en "${nombreVal}"?`)))
      if (!ok) return

      openLoadingModal('Editando categoría...')
      try {
        const response = await fetch(backendUrl(`/api/admin/catalogo/categoria/${id}/editar/`), {
          method: 'POST',
          credentials: 'include',
          body: formData,
        })
        const data = await response.json().catch(() => ({}))
        if (!response.ok || !data.ok) {
          if (catalogEditMessage) catalogEditMessage.textContent = data.message || 'No se pudo editar la categoría.'
          return
        }

        close()
        window.location.reload()
      } finally {
        closeLoadingModal()
      }
    })
  }

  const wireCategoriaActions = () => {
    document.querySelectorAll('[data-admin-actions]').forEach((actions) => actions.removeAttribute('hidden'))
    document.querySelectorAll('[data-edit-categoria]').forEach((btn) => {
      const id = btn.getAttribute('data-edit-categoria')
      const card = btn.closest('.product')
      const nombre = card?.querySelector('.product-title')?.textContent?.trim() || ''
      const descripcion = card?.querySelector('.product-link')?.getAttribute('title') || ''
      btn.addEventListener('click', () => openEditCategoriaModal(id, nombre, descripcion))
    })
    document.querySelectorAll('[data-delete-categoria]').forEach((btn) => {
      const id = btn.getAttribute('data-delete-categoria')
      const card = btn.closest('.product')
      const nombre = card?.querySelector('.product-title')?.textContent?.trim() || ''
      btn.addEventListener('click', async () => {
        const ok = await (window.showStyledConfirm
          ? window.showStyledConfirm(`¿Eliminar la categoría "${nombre}"?`)
          : Promise.resolve(confirm(`¿Eliminar la categoría "${nombre}"?`)))
        if (!ok) return
        openLoadingModal('Eliminando categoría...')
        try {
          const response = await fetch(backendUrl(`/api/admin/catalogo/categoria/${id}/eliminar/`), {
            method: 'POST',
            credentials: 'include',
          })
          const data = await response.json().catch(() => ({}))
          if (!response.ok || !data.ok) {
            alert(data.message || 'No se pudo eliminar la categoría.')
            return
          }
          window.location.reload()
        } finally {
          closeLoadingModal()
        }
      })
    })
  }

  const applyAdminCatalogUi = () => {
    if (!grid) return
    showAdminCta()
    wireCategoriaActions()
  }

  const initAddCategoria = async () => {
    const response = await fetch(backendUrl('/api/auth/session/'), { credentials: 'include' })
    if (!response.ok) return
    const data = await response.json()
    if (!canManageCatalog(data)) return

    showAdminCta()
    if (grid) wireCategoriaActions()
  }

  window.initAddCategoria = initAddCategoria
  initAddCategoria()

  const renderFreeCategories = (items) => {
    if (!grid) return
    grid.replaceChildren()

    items.forEach((cat) => {
      const article = document.createElement('div')
      article.className = 'product'
      article.dataset.categoriaId = String(cat.id)
      article.dataset.categoriaNombre = cat.nombre || ''
      article.dataset.categoriaDescripcion = cat.descripcion || ''

      const link = document.createElement('a')
      link.className = 'product-link'
      link.href = `/gratis/${cat.slug}/`
      link.title = cat.descripcion || ''

      if (cat.imagen) {
        const img = document.createElement('img')
        img.src = cat.imagen
        img.alt = cat.descripcion || cat.nombre || ''
        img.width = 286
        img.height = 372
        img.loading = 'lazy'
        link.appendChild(img)
      } else {
        const card = document.createElement('div')
        card.className = 'card'
        const img = document.createElement('img')
        img.src = '/static/web/assets/g345.webp'
        img.alt = 'Sin imagen'
        img.width = 190
        img.height = 89
        card.appendChild(img)
        link.appendChild(card)
      }

      const title = document.createElement('a')
      title.className = 'product-title'
      title.href = `/gratis/${cat.slug}/`
      title.title = cat.descripcion || ''
      title.textContent = cat.nombre || ''

      const actions = document.createElement('div')
      actions.className = 'published-actions'
      actions.setAttribute('data-admin-actions', '')
      actions.hidden = true

      const editButton = document.createElement('button')
      editButton.className = 'btn'
      editButton.type = 'button'
      editButton.setAttribute('data-edit-categoria', String(cat.id))
      editButton.textContent = 'Editar'

      const deleteButton = document.createElement('button')
      deleteButton.className = 'btn btn-secondary'
      deleteButton.type = 'button'
      deleteButton.setAttribute('data-delete-categoria', String(cat.id))
      deleteButton.textContent = 'Eliminar'

      actions.append(editButton, deleteButton)
      article.append(link, title, actions)
      grid.appendChild(article)
    })
    grid.removeAttribute('hidden')
    emptyBlock?.setAttribute('hidden', '')
  }

  const hydrateFreeCategories = async () => {
    if (!grid || grid.children.length > 0) return
    try {
      const [freeRes, catalogRes] = await Promise.all([
        fetch(backendUrl('/api/categorias/')),
        fetch(backendUrl('/api/catalog/categorias/')),
      ])
      const [freeData, catalogData] = await Promise.all([freeRes.json(), catalogRes.json()])
      const categorias = freeData.results || []
      const categoriasCatalogo = catalogData.results || []
      const categoriasConImagen = new Map(categorias.map((item) => [item.slug, item]))
      const categoriasRender = categoriasCatalogo
        .sort((a, b) => Number(b.es_gratuita) - Number(a.es_gratuita) || a.nombre.localeCompare(b.nombre, 'es'))
        .map((item) => {
          const fromList = categoriasConImagen.get(item.slug)
          return {
            ...item,
            descripcion: fromList?.descripcion || '',
            imagen: fromList?.imagen || null,
          }
        })

      if (categoriasRender.length > 0) {
        renderFreeCategories(categoriasRender)
        applyAdminCatalogUi()
      }
    } catch (error) {
      // keep the SSR fallback if the API isn't reachable in local dev
    }
  }

  hydrateFreeCategories()
</script>
