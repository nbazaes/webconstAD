---
import BaseLayout from '../layouts/BaseLayout.astro'

const products = []
---

<BaseLayout title="Productos | Constant Archivos Digitales" page="productos">
  <main class="content">
    <section class="products-hero">
      <h2>PRODUCTOS</h2>
      <p class="lead">Archivos para <em>imprimir</em> o trabajar <em>digitalmente</em></p>
    </section>

    <section class="products-grid" data-products-grid hidden></section>
    <section class="products-hero text-block" data-products-empty hidden>
      <p>Aún no hay productos de pago publicados.</p>
    </section>
    <section class="products-hero text-block" data-products-loading>
      <p>Cargando productos...</p>
    </section>
    <section class="products-grid" data-colecciones-grid hidden>
      <h3 class="colecciones-title">Colecciones</h3>
    </section>


    <div class="global-loading-modal" data-global-loading hidden>
      <div class="global-loading-modal__backdrop"></div>
      <div class="global-loading-modal__panel">
        <span class="loading-spinner" aria-hidden="true"></span>
        <p>Procesando...</p>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: inherit;
  }

  .product-collection {
    font-family: 'PT Serif', serif;
    font-weight: 700;
    font-size: 1.2rem;
    margin-top: 10px;
  }

  .product-title {
    font-family: 'PT Serif', serif;
    font-weight: 400;
    font-size: 1.1rem;
  }


  @media (max-width: 700px) {
    .product-collection {
      font-size: 1.05rem;
    }

    .product-title {
      font-size: 1rem;
    }

  }

  .catalog-cta {
    border: 1px dashed #d9cfc6;
    border-radius: 12px;
    background: #fffaf5;
    padding: 18px;
    display: grid;
    gap: 12px;
    text-align: center;
    align-content: center;
    min-height: 210px;
  }

  .catalog-cta h3 {
    margin: 0;
    font-size: 1.2rem;
  }

  .catalog-cta p {
    margin: 0;
    color: #5b4f46;
  }

  .catalog-cta__actions {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .catalog-cta__helper {
    font-size: 0.95rem;
    color: #6d6158;
  }

  .colecciones-title {
    width: 100%;
    font-family: 'PT Serif', serif;
    font-size: 1.4rem;
    margin: 24px 0 12px;
    grid-column: 1 / -1;
  }
</style>

<script>
  const catalogBackendOrigin = window.location.origin
  const catalogBackendUrl = (path) => `${catalogBackendOrigin}${path}`
  const productsGrid = document.querySelector('[data-products-grid]')
  const emptyState = document.querySelector('[data-products-empty]')
  const loadingState = document.querySelector('[data-products-loading]')
  const globalLoading = document.querySelector('[data-global-loading]')
  const coleccionesGrid = document.querySelector('[data-colecciones-grid]')

  const canManageCatalog = (data) =>
    Boolean(
      data?.authenticated &&
        (data.user?.rol === 'admin' || data.user?.rol === 'artista' || data.user?.is_staff || data.user?.is_superuser)
    )

  const openColeccionModal = async () => {
    const modal = document.createElement('div')
    modal.className = 'catalog-modal'
    modal.innerHTML = `
      <div class="catalog-modal__backdrop" data-close-catalog></div>
      <div class="catalog-modal__panel" role="dialog" aria-modal="true">
        <h3>Nueva colección</h3>
        <form class="auth-form" data-catalog-form>
          <input type="hidden" name="tipo" value="coleccion" />
          <label>Nombre</label><input name="nombre" type="text" required />
          <label>Imagen (opcional)</label><input name="imagen" type="file" accept="image/*" />
          <label>Descripción (imagen opcional)</label><input name="descripcion" type="file" accept="image/*" />
          <div class="published-actions">
            <button class="btn" type="submit">Crear</button>
            <button class="btn btn-secondary" type="button" data-close-catalog>Cancelar</button>
          </div>
        </form>
        <p class="auth-message" data-catalog-message></p>
      </div>
    `

    document.body.appendChild(modal)
    const close = () => modal.remove()
    modal.querySelectorAll('[data-close-catalog]').forEach((el) => el.addEventListener('click', close))

    const form = modal.querySelector('[data-catalog-form]')
    const message = modal.querySelector('[data-catalog-message]')
    form?.addEventListener('submit', async (event) => {
      event.preventDefault()
      if (message) message.textContent = ''

      const formData = new FormData(form)
      const nombre = String(formData.get('nombre') || '').trim()
      if (!nombre) {
        if (message) message.textContent = 'Nombre es obligatorio.'
        return
      }

      const ok = await (window.showStyledConfirm
        ? window.showStyledConfirm(`¿Crear la colección "${nombre}"?`)
        : Promise.resolve(confirm(`¿Crear la colección "${nombre}"?`)))
      if (!ok) return

      const response = await fetch(catalogBackendUrl('/api/admin/catalogo/crear/'), {
        method: 'POST',
        credentials: 'include',
        body: formData,
      })
      const data = await response.json().catch(() => ({}))
      if (!response.ok || !data.ok) {
        if (message) message.textContent = data.message || 'No se pudo crear la colección.'
        return
      }

      close()
      window.location.reload()
    })
  }

  const insertColeccionCard = (target) => {
    if (!target || target.querySelector('[data-add-coleccion]')) return
    const wrapper = document.createElement('article')
    wrapper.className = 'product'
    wrapper.setAttribute('data-add-coleccion', '')
    wrapper.innerHTML = `
      <div class="catalog-cta" ${target === emptyState ? 'style="margin-top: 16px;"' : ''}>
        <h3>Agregar colección</h3>
        <!--<p>Publica una nueva colección para tus productos de pago.</p>-->
        <div class="catalog-cta__actions">
          <button class="btn" type="button" data-open-add-coleccion>Crear colección</button>
          <a class="btn btn-secondary" href="/publicar/">Ir a publicar</a>
        </div>
        <!--<div class="catalog-cta__helper">Disponible para admins y artistas.</div>-->
      </div>
    `
    target.prepend(wrapper)
    wrapper.querySelector('[data-open-add-coleccion]')?.addEventListener('click', openColeccionModal)
  }

  const initColeccionCta = async () => {
    if (!productsGrid && !emptyState) return
    const response = await fetch(catalogBackendUrl('/api/auth/session/'), { credentials: 'include' })
    if (!response.ok) return
    const data = await response.json()
    if (!canManageCatalog(data)) return
    if (productsGrid && !productsGrid.hasAttribute('hidden')) {
      insertColeccionCard(productsGrid)
      return
    }
    if (emptyState && !emptyState.hasAttribute('hidden')) {
      insertColeccionCard(emptyState)
      return
    }
    insertColeccionCard(productsGrid || emptyState)
  }

  const openEditColeccionModal = (id, nombre) => {
    const modal = document.createElement('div')
    modal.className = 'catalog-modal'
    modal.innerHTML = `
      <div class="catalog-modal__backdrop" data-close-catalog></div>
      <div class="catalog-modal__panel" role="dialog" aria-modal="true">
        <h3>Editar colección</h3>
        <form class="auth-form" data-catalog-form>
          <input type="hidden" name="tipo" value="coleccion" />
          <label>Nombre</label><input name="nombre" type="text" value="${nombre}" required />
          <label>Imagen (opcional)</label><input name="imagen" type="file" accept="image/*" />
          <label>Descripción (imagen opcional)</label><input name="descripcion" type="file" accept="image/*" />
          <div class="published-actions">
            <button class="btn" type="submit">Guardar</button>
            <button class="btn btn-secondary" type="button" data-close-catalog>Cancelar</button>
          </div>
        </form>
        <p class="auth-message" data-catalog-message></p>
      </div>
    `

    document.body.appendChild(modal)
    const close = () => modal.remove()
    modal.querySelectorAll('[data-close-catalog]').forEach((el) => el.addEventListener('click', close))

    const form = modal.querySelector('[data-catalog-form]')
    const message = modal.querySelector('[data-catalog-message]')
    form?.addEventListener('submit', async (event) => {
      event.preventDefault()
      if (message) message.textContent = ''

      const formData = new FormData(form)
      const nombreVal = String(formData.get('nombre') || '').trim()
      if (!nombreVal) {
        if (message) message.textContent = 'Nombre es obligatorio.'
        return
      }

      const ok = await (window.showStyledConfirm
        ? window.showStyledConfirm(`¿Guardar cambios en "${nombreVal}"?`)
        : Promise.resolve(confirm(`¿Guardar cambios en "${nombreVal}"?`)))
      if (!ok) return

      const response = await fetch(catalogBackendUrl(`/api/admin/catalogo/coleccion/${id}/editar/`), {
        method: 'POST',
        credentials: 'include',
        body: formData,
      })
      const data = await response.json().catch(() => ({}))
      if (!response.ok || !data.ok) {
        if (message) message.textContent = data.message || 'No se pudo editar la colección.'
        return
      }

      close()
      window.location.reload()
    })
  }

  const loadColecciones = async () => {
    if (!coleccionesGrid) return
    try {
      const response = await fetch(catalogBackendUrl('/api/catalog/colecciones/'))
      if (!response.ok) throw new Error()
      const data = await response.json()
      const items = data.results || []
      if (!items.length) return

      const sessionRes = await fetch(catalogBackendUrl('/api/auth/session/'), { credentials: 'include' })
      const sessionData = sessionRes.ok ? await sessionRes.json() : { authenticated: false }
      const isAdmin = canManageCatalog(sessionData)

      coleccionesGrid.innerHTML = '<h3 class="colecciones-title">Colecciones</h3>'
      items.forEach((col) => {
        const card = document.createElement('article')
        card.className = 'product'
        card.innerHTML = `
          <div class="product-card">
            ${col.imagen ? `<img src="${col.imagen}" alt="${col.nombre}" width="286" height="286" loading="lazy" />` : '<div class="card"><img src="/static/web/assets/g345.webp" alt="Sin imagen" width="190" height="89" /></div>'}
            <br />
            <span class="product-collection"><em>${col.nombre}</em></span>
          </div>
          ${isAdmin ? `
          <div class="published-actions" data-admin-actions>
            <button class="btn" type="button" data-edit-coleccion="${col.id}">Editar</button>
            <button class="btn btn-secondary" type="button" data-delete-coleccion="${col.id}">Eliminar</button>
          </div>` : ''}
        `
        coleccionesGrid.appendChild(card)
        if (isAdmin) {
          card.querySelector('[data-edit-coleccion]')?.addEventListener('click', () => openEditColeccionModal(col.id, col.nombre))
          card.querySelector('[data-delete-coleccion]')?.addEventListener('click', async () => {
            const ok = await (window.showStyledConfirm
              ? window.showStyledConfirm(`¿Eliminar la colección "${col.nombre}"?`)
              : Promise.resolve(confirm(`¿Eliminar la colección "${col.nombre}"?`)))
            if (!ok) return
            const delRes = await fetch(catalogBackendUrl(`/api/admin/catalogo/coleccion/${col.id}/eliminar/`), {
              method: 'POST',
              credentials: 'include',
            })
            const delData = await delRes.json().catch(() => ({}))
            if (!delRes.ok || !delData.ok) {
              alert(delData.message || 'No se pudo eliminar la colección.')
              return
            }
            window.location.reload()
          })
        }
      })
      coleccionesGrid.removeAttribute('hidden')
    } catch {
      // colecciones grid stays hidden
    }
  }

  window.initColeccionCta = initColeccionCta

  const openLoadingModal = (text = 'Procesando...') => {
    if (!globalLoading) return
    const p = globalLoading.querySelector('p')
    if (p) p.textContent = text
    globalLoading.removeAttribute('hidden')
  }

  const closeLoadingModal = () => {
    globalLoading?.setAttribute('hidden', '')
  }

  const ensureAdminUi = async () => {
    const response = await fetch(catalogBackendUrl('/api/auth/session/'), { credentials: 'include' })
    if (!response.ok) return false
    const data = await response.json()
    return Boolean(data.authenticated && (data.user?.rol === 'admin' || data.user?.rol === 'artista' || data.user?.is_staff || data.user?.is_superuser))
  }

  const createEditModal = async (product) => {
    const [catRes, colRes] = await Promise.all([
      fetch(catalogBackendUrl('/api/catalog/categorias/'), { credentials: 'include' }),
      fetch(catalogBackendUrl('/api/catalog/colecciones/'), { credentials: 'include' }),
    ])
    const catData = await catRes.json()
    const colData = await colRes.json()
    const categorias = (catData.results || []).filter((c) => c.es_gratuita)
    const colecciones = colData.results || []

    const modal = document.createElement('div')
    modal.className = 'edit-modal'
    modal.innerHTML = `
      <div class="edit-modal__backdrop" data-close-edit></div>
      <div class="edit-modal__panel" role="dialog" aria-modal="true">
        <h3>Editar producto</h3>
        <form class="auth-form" data-edit-form>
          <label>Nombre</label><input name="nombre" type="text" value="${product.nombre || ''}" required />
          <label>Descripción</label><textarea name="descripcion" rows="3">${product.descripcion || ''}</textarea>
          <label>Imagen preview (opcional)</label><input name="imagen" type="file" accept="image/*" />
          <label>Preview de paginas (opcional)</label><input name="preview_imagen" type="file" accept="image/*" />
          <label>¿Es gratuito?</label>
          <select name="es_gratuito" data-edit-gratis>
            <option value="true" ${product.es_gratuito ? 'selected' : ''}>Sí</option>
            <option value="false" ${!product.es_gratuito ? 'selected' : ''}>No</option>
          </select>
          <div data-edit-categoria-wrap ${product.es_gratuito ? '' : 'hidden'}>
            <label>Categoria</label>
            <select name="categoria_id">
              <option value="">Sin categoria</option>
              ${categorias.map((c) => `<option value="${c.id}" ${product.categoria_id === c.id ? 'selected' : ''}>${c.nombre}</option>`).join('')}
            </select>
          </div>
          <div data-edit-coleccion-wrap ${product.es_gratuito ? 'hidden' : ''}>
            <label>Coleccion</label>
            <select name="coleccion_id">
              <option value="">Sin coleccion</option>
              ${colecciones.map((c) => `<option value="${c.id}" ${product.coleccion_id === c.id ? 'selected' : ''}>${c.nombre}</option>`).join('')}
            </select>
          </div>
          <label>Paginas</label><input name="paginas" type="number" min="1" step="1" value="${product.paginas || ''}" />
          <div data-edit-precio-wrap ${product.es_gratuito ? 'hidden' : ''}>
            <label>Precio</label><input name="precio" type="number" min="0" step="1" value="${product.precio || ''}" />
          </div>
          <label>Activo?</label>
          <select name="activo"><option value="true" ${product.activo ? 'selected' : ''}>Si</option><option value="false" ${!product.activo ? 'selected' : ''}>No</option></select>
          <div class="published-actions">
            <button class="btn" type="submit">Guardar</button>
            <button class="btn btn-secondary" type="button" data-close-edit>Cancelar</button>
          </div>
        </form>
      </div>
    `

    document.body.appendChild(modal)
    const close = () => modal.remove()
    modal.querySelectorAll('[data-close-edit]').forEach((el) => el.addEventListener('click', close))

    const gratisSelect = modal.querySelector('[data-edit-gratis]')
    const categoriaWrap = modal.querySelector('[data-edit-categoria-wrap]')
    const coleccionWrap = modal.querySelector('[data-edit-coleccion-wrap]')
    const precioWrap = modal.querySelector('[data-edit-precio-wrap]')
    const categoriaField = modal.querySelector('select[name="categoria_id"]')
    const coleccionField = modal.querySelector('select[name="coleccion_id"]')
    const precioField = modal.querySelector('input[name="precio"]')

    const applyEditRules = () => {
      const isFree = gratisSelect?.value === 'true'
      if (categoriaWrap) categoriaWrap.hidden = !isFree
      if (coleccionWrap) coleccionWrap.hidden = isFree
      if (precioWrap) precioWrap.hidden = isFree
      if (categoriaField) categoriaField.disabled = !isFree
      if (coleccionField) coleccionField.disabled = isFree
      if (precioField) precioField.disabled = isFree
      if (isFree) {
        if (coleccionField) coleccionField.value = ''
        if (precioField) precioField.value = ''
      } else if (categoriaField) {
        categoriaField.value = ''
      }
    }
    gratisSelect?.addEventListener('change', applyEditRules)
    applyEditRules()

    const form = modal.querySelector('[data-edit-form]')
    form?.addEventListener('submit', async (event) => {
      event.preventDefault()
      const ok = await (window.showStyledConfirm
        ? window.showStyledConfirm(`Confirmas guardar cambios en ${product.nombre}?`)
        : Promise.resolve(confirm(`Confirmas guardar cambios en ${product.nombre}?`)))
      if (!ok) return

      const formData = new FormData(form)
      openLoadingModal('Guardando cambios...')
      const response = await fetch(catalogBackendUrl(`/api/admin/productos/${product.id}/editar/`), {
        method: 'POST',
        credentials: 'include',
        body: formData,
      })
      closeLoadingModal()
      if (!response.ok) return
      window.location.reload()
    })
  }

  const wireAdminActions = async () => {
    const isAdmin = await ensureAdminUi()
    if (!isAdmin) {
      document.querySelectorAll('[data-admin-actions]').forEach((actions) => actions.setAttribute('hidden', ''))
      return
    }

    document.querySelectorAll('[data-admin-actions]').forEach((actions) => actions.removeAttribute('hidden'))
    document.querySelectorAll('[data-admin-product]').forEach((card) => {
      const product = JSON.parse(card.getAttribute('data-product-json') || '{}')

      card.querySelector('[data-delete-product]')?.addEventListener('click', async () => {
        const ok = await (window.showStyledConfirm
          ? window.showStyledConfirm(`Confirmas eliminar ${product.nombre}?`)
          : Promise.resolve(confirm(`Confirmas eliminar ${product.nombre}?`)))
        if (!ok) return

        openLoadingModal('Eliminando producto...')
        const response = await fetch(catalogBackendUrl(`/api/admin/productos/${product.id}/eliminar/`), {
          method: 'POST',
          credentials: 'include',
        })
        closeLoadingModal()
        if (!response.ok) return
        window.location.reload()
      })

      card.querySelector('[data-edit-product]')?.addEventListener('click', () => createEditModal(product))
    })
  }

  const renderProducts = (products) => {
    if (!productsGrid) return
    if (!products.length) {
      emptyState?.removeAttribute('hidden')
      productsGrid.setAttribute('hidden', '')
      window.initColeccionCta?.()
      return
    }

    productsGrid.innerHTML = products
      .map(
        (product) => `
          <article class="product" data-admin-product data-product-id="${product.id}" data-product-json='${JSON.stringify(product).replace(/'/g, '&apos;')}'>
            <a href="/productos/${product.slug}/" class="product-card" title="${product.descripcion || product.nombre}">
              <img src="${product.imagen || '/static/web/assets/hero1.webp'}" alt="${product.descripcion || product.nombre}" width="286" height="286" loading="lazy" />
              <br />
              <span class="product-collection"><em>${product.coleccion || 'Coleccion'}</em></span>
              <br />
              <span class="product-title">${product.nombre}</span>
            </a>
            <div class="published-actions" data-admin-actions hidden>
              <button class="btn" type="button" data-edit-product>Editar</button>
              <button class="btn btn-secondary" type="button" data-delete-product>Eliminar</button>
            </div>
          </article>
        `
      )
      .join('')

    productsGrid.removeAttribute('hidden')
    wireAdminActions()
    window.initColeccionCta?.()
  }

  const loadProducts = async () => {
    if (!productsGrid) return
    loadingState?.removeAttribute('hidden')
    emptyState?.setAttribute('hidden', '')
    productsGrid.setAttribute('hidden', '')
    try {
      const response = await fetch(catalogBackendUrl('/api/productos/'))
      if (!response.ok) throw new Error('no se pudo cargar')
      const data = await response.json()
      const items = (data.results || []).filter((item) => !item.es_gratuito && item.coleccion)
      renderProducts(items)
    } catch {
      emptyState?.removeAttribute('hidden')
    } finally {
      loadingState?.setAttribute('hidden', '')
    }
  }

  loadProducts()
  initColeccionCta()
  loadColecciones()
</script>


