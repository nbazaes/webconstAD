---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getApiOrigin } from '../lib/api-origin'

export const prerender = false

const apiOrigin = getApiOrigin(Astro)

let colecciones = []
try {
  const apiBase = new URL('/api/', apiOrigin)
  const respuesta = await fetch(new URL('colecciones/', apiBase))
  const datos = await respuesta.json()
  colecciones = datos.results || []
} catch (e) {
  // API may not be available during build; use empty data
}

const showColecciones = colecciones.length > 0
---

<BaseLayout title="Productos | Constant Archivos Digitales" page="productos">
  <main class="content">
    <section class="products-hero text-block">
      <h2>PRODUCTOS</h2>
      <p class="lead">Archivos para <em>imprimir</em> o trabajar <em>digitalmente</em></p>
    </section>

    <div class="catalog-cta-wrapper" data-catalog-cta hidden>
      <div class="catalog-cta">
        <h3>Agregar colección</h3>
        <p>Crea una nueva colección desde aquí.</p>
        <div class="catalog-cta__actions">
          <button class="btn" type="button" data-open-add-coleccion>Crear colección</button>
          <a class="btn btn-secondary" href="/publicar/">Ir a publicar</a>
        </div>
        <div class="catalog-cta__helper">Disponible para admins y artistas.</div>
      </div>
    </div>

    <section class="products-grid" data-product-grid hidden={!showColecciones}>
      {colecciones.map((col) => (
        <div class="product">
          <a href={`/productos/coleccion/${col.slug}/`} class="product-link">
            {col.imagen ? (
              <img src={col.imagen} alt={col.nombre} width="286" height="372" loading="lazy" />
            ) : (
              <div class="card">
                <img src="/static/web/assets/hero1.webp" alt="Sin imagen" width="190" height="89" loading="lazy" />
              </div>
            )}
          </a>
          <a href={`/productos/coleccion/${col.slug}/`} class="product-title">{col.nombre}</a>
          <span class="product-count">{col.product_count} producto{col.product_count !== 1 ? 's' : ''}</span>
          <div class="published-actions" data-admin-actions hidden>
            <button class="btn" type="button" data-edit-coleccion={col.id}>Editar</button>
            <button class="btn btn-secondary" type="button" data-delete-coleccion={col.id}>Eliminar</button>
          </div>
        </div>
      ))}

      <div class="product product--all">
        <a href="/productos/todos/" class="product-title product-title--all">Ver todos los productos</a>
        <span class="product-count">Explorar catálogo completo</span>
      </div>
    </section>

    <section class="products-hero text-block" data-free-empty hidden={showColecciones}>
      <p>Aún no hay colecciones publicadas.</p>
    </section>

    <div class="go-top-wrapper">
      <a href="javascript:void(0)" class="btn btn-secondary go-top" onclick="window.scrollTo({top:0,behavior:'smooth'});return false">Ir arriba</a>
    </div>

    <div class="global-loading-modal" data-global-loading hidden>
      <div class="global-loading-modal__backdrop"></div>
      <div class="global-loading-modal__panel">
        <span class="loading-spinner" aria-hidden="true"></span>
        <p>Procesando...</p>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .product-link {
    display: block;
    text-decoration: none;
    width: 286px;
    height: 372px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .product-link img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    border-radius: 6px;
    box-shadow: none;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .product-link:hover img,
  .product-link:focus-visible img,
  .product-link:active img {
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.12);
    transform: translateY(-3px);
  }

  .product-title {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-top: 12px;
    color: #111;
    text-decoration: none;
    font-family: 'PT Serif', serif;
    font-weight: 600;
    font-size: 1.2rem;
  }
  .product-title span {
    display: block;
    font-weight: 400;
    color: #333;
    font-size: 1rem;
  }

  .product--all {
    justify-content: center;
    padding-top: 20px;
    margin-top: 10px;
    border-top: 1px solid #e2d7ce;
    grid-column: 1 / -1;
  }

  .product-title--all {
    font-weight: 700;
    font-size: 1.3rem;
    color: #243233;
    text-align: center;
    transition: color 0.2s;
  }
  .product-title--all:hover {
    color: #5a4f45;
  }

  .product-count {
    font-size: 0.9rem;
    color: #6a5f55;
    margin-top: 2px;
  }

  .catalog-cta {
    border: 1px dashed #d9cfc6;
    border-radius: 12px;
    background: #fffaf5;
    padding: 18px;
    display: grid;
    gap: 12px;
    text-align: center;
    align-content: center;
    min-height: 210px;
    width: 100%;
    box-sizing: border-box;
    font-size: 1rem;
  }

  .catalog-cta h3 {
    margin: 0;
    font-size: 1.2rem;
  }

  .catalog-cta p {
    margin: 0;
    color: #5b4f46;
  }

  .catalog-cta__actions {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .catalog-cta__actions .btn {
    white-space: nowrap;
  }

  .catalog-cta__helper {
    font-size: 0.95rem;
    color: #6d6158;
  }

  .catalog-cta-wrapper {
    max-width: 1100px;
    margin: 0 auto 28px;
    padding: 0 20px 80px;
  }

  @media (max-width: 720px) {
    .products-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
      padding: 0 8px;
    }

    .product-link {
      width: 150px;
      height: 195px;
    }

    .product-title {
      font-size: 1rem;
      margin-top: 8px;
    }

    .catalog-cta-wrapper {
      padding: 0 8px 64px;
    }

    .catalog-cta {
      padding: 14px;
      min-height: 160px;
    }

    .catalog-cta__actions {
      gap: 16px;
    }

    .product-count {
      font-size: 0.8rem;
    }
  }
</style>

<script>
  const backendOrigin = window.location.origin
  const backendUrl = (path) => `${backendOrigin}${path}`
  const grid = document.querySelector('[data-product-grid]')

  const openLoadingModal = (text = 'Procesando...') => {
    const el = document.querySelector('[data-global-loading]')
    if (!el) return
    const p = el.querySelector('p')
    if (p) p.textContent = text
    el.removeAttribute('hidden')
  }

  const closeLoadingModal = () => {
    const el = document.querySelector('[data-global-loading]')
    el?.setAttribute('hidden', '')
  }

  const canManageCatalog = (data) =>
    Boolean(
      data?.authenticated &&
        (data.user?.rol === 'admin' || data.user?.rol === 'artista' || data.user?.is_staff || data.user?.is_superuser)
    )

  const ctaBlock = document.querySelector('[data-catalog-cta]')

  const showAdminCta = () => {
    if (!ctaBlock || ctaBlock.hasAttribute('shown')) return
    ctaBlock.removeAttribute('hidden')
    ctaBlock.setAttribute('shown', '')
    ctaBlock.querySelector('[data-open-add-coleccion]')?.addEventListener('click', openAddColeccionModal)
  }

  const openAddColeccionModal = async () => {
    const modal = document.createElement('div')
    modal.className = 'catalog-modal'
    modal.innerHTML = `
      <div class="catalog-modal__backdrop" data-close-catalog></div>
      <div class="catalog-modal__panel" role="dialog" aria-modal="true">
        <h3>Nueva colección</h3>
        <form class="auth-form" data-catalog-form>
          <input type="hidden" name="tipo" value="coleccion" />
          <label>Nombre</label><input name="nombre" type="text" required />
          <label>Imagen (opcional)</label><input name="imagen" type="file" accept="image/*" />
          <div class="published-actions">
            <button class="btn" type="submit">Crear</button>
            <button class="btn btn-secondary" type="button" data-close-catalog>Cancelar</button>
          </div>
        </form>
        <p class="auth-message" data-catalog-message></p>
      </div>
    `

    document.body.appendChild(modal)
    const close = () => modal.remove()
    modal.querySelectorAll('[data-close-catalog]').forEach((el) => el.addEventListener('click', close))

    const form = modal.querySelector('[data-catalog-form]')
    const message = modal.querySelector('[data-catalog-message]')
    form?.addEventListener('submit', async (event) => {
      event.preventDefault()
      if (message) message.textContent = ''

      const formData = new FormData(form)
      const nombre = String(formData.get('nombre') || '').trim()
      if (!nombre) {
        if (message) message.textContent = 'Nombre es obligatorio.'
        return
      }

      const ok = await (window.showStyledConfirm
        ? window.showStyledConfirm(`¿Crear la colección "${nombre}"?`)
        : Promise.resolve(confirm(`¿Crear la colección "${nombre}"?`)))
      if (!ok) return

      openLoadingModal('Creando colección...')
      try {
        const response = await fetch(backendUrl('/api/admin/catalogo/crear/'), {
          method: 'POST',
          credentials: 'include',
          body: formData,
        })
        const data = await response.json().catch(() => ({}))
        if (!response.ok || !data.ok) {
          if (message) message.textContent = data.message || 'No se pudo crear la colección.'
          return
        }

        close()
        window.location.reload()
      } finally {
        closeLoadingModal()
      }
    })
  }

  const openEditColeccionModal = (id, nombre) => {
    const modal = document.createElement('div')
    modal.className = 'catalog-modal'
    modal.innerHTML = `
      <div class="catalog-modal__backdrop" data-close-catalog></div>
      <div class="catalog-modal__panel" role="dialog" aria-modal="true">
        <h3>Editar colección</h3>
        <form class="auth-form" data-catalog-form>
          <input type="hidden" name="tipo" value="coleccion" />
          <label>Nombre</label><input name="nombre" type="text" required value="${nombre}" />
          <label>Imagen (opcional)</label><input name="imagen" type="file" accept="image/*" />
          <div class="published-actions">
            <button class="btn" type="submit">Guardar</button>
            <button class="btn btn-secondary" type="button" data-close-catalog>Cancelar</button>
          </div>
        </form>
        <p class="auth-message" data-catalog-message></p>
      </div>
    `

    document.body.appendChild(modal)
    const close = () => modal.remove()
    modal.querySelectorAll('[data-close-catalog]').forEach((el) => el.addEventListener('click', close))

    const form = modal.querySelector('[data-catalog-form]')
    const message = modal.querySelector('[data-catalog-message]')
    form?.addEventListener('submit', async (event) => {
      event.preventDefault()
      if (message) message.textContent = ''

      const formData = new FormData(form)
      const nombreVal = String(formData.get('nombre') || '').trim()
      if (!nombreVal) {
        if (message) message.textContent = 'Nombre es obligatorio.'
        return
      }

      const ok = await (window.showStyledConfirm
        ? window.showStyledConfirm(`¿Guardar cambios en "${nombreVal}"?`)
        : Promise.resolve(confirm(`¿Guardar cambios en "${nombreVal}"?`)))
      if (!ok) return

      openLoadingModal('Editando colección...')
      try {
        const response = await fetch(backendUrl(`/api/admin/catalogo/coleccion/${id}/editar/`), {
          method: 'POST',
          credentials: 'include',
          body: formData,
        })
        const data = await response.json().catch(() => ({}))
        if (!response.ok || !data.ok) {
          if (message) message.textContent = data.message || 'No se pudo editar la colección.'
          return
        }

        close()
        window.location.reload()
      } finally {
        closeLoadingModal()
      }
    })
  }

  const wireColeccionActions = () => {
    document.querySelectorAll('[data-admin-actions]').forEach((actions) => actions.removeAttribute('hidden'))
    document.querySelectorAll('[data-edit-coleccion]').forEach((btn) => {
      const id = btn.getAttribute('data-edit-coleccion')
      const card = btn.closest('.product')
      const nombre = card?.querySelector('.product-title')?.textContent?.trim() || ''
      btn.addEventListener('click', () => openEditColeccionModal(id, nombre))
    })
    document.querySelectorAll('[data-delete-coleccion]').forEach((btn) => {
      const id = btn.getAttribute('data-delete-coleccion')
      const card = btn.closest('.product')
      const nombre = card?.querySelector('.product-title')?.textContent?.trim() || ''
      btn.addEventListener('click', async () => {
        const ok = await (window.showStyledConfirm
          ? window.showStyledConfirm(`¿Eliminar la colección "${nombre}"?`)
          : Promise.resolve(confirm(`¿Eliminar la colección "${nombre}"?`)))
        if (!ok) return
        openLoadingModal('Eliminando colección...')
        try {
          const response = await fetch(backendUrl(`/api/admin/catalogo/coleccion/${id}/eliminar/`), {
            method: 'POST',
            credentials: 'include',
          })
          const data = await response.json().catch(() => ({}))
          if (!response.ok || !data.ok) {
            alert(data.message || 'No se pudo eliminar la colección.')
            return
          }
          window.location.reload()
        } finally {
          closeLoadingModal()
        }
      })
    })
  }

  const applyAdminCatalogUi = () => {
    if (!grid) return
    showAdminCta()
    wireColeccionActions()
  }

  const initColeccionCta = async () => {
    const response = await fetch(backendUrl('/api/auth/session/'), { credentials: 'include' })
    if (!response.ok) return
    const data = await response.json()
    if (!canManageCatalog(data)) return

    showAdminCta()
    if (grid) wireColeccionActions()
  }

  initColeccionCta()
</script>
