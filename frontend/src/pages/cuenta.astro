---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Cuenta | Constant Archivos Digitales" page="cuenta">
  <main class="content">
    <section class="products-hero text-block">
      <h2>CUENTA</h2>
      <p class="lead">Administra tus datos y revisa tus compras.</p>
    </section>

    <div class="flow-result-banner" data-flow-result hidden></div>

    <section class="products-hero text-block">
      <div class="cuenta-layout" data-cuenta-layout hidden>
        <aside class="cuenta-sidebar" data-cuenta-sidebar>
          <button class="cuenta-tab cuenta-tab--active" type="button" data-tab-perfil>Perfil</button>
          <button class="cuenta-tab" type="button" data-tab-compras>Mis Compras</button>
          <button class="cuenta-tab" type="button" data-tab-medios>Medios de pago</button>
        </aside>

        <div class="cuenta-content">
          <section class="cuenta-panel" data-panel-perfil>
            <div class="account-page-card" data-account-page>
              <p>Cargando información de tu cuenta...</p>
            </div>
          </section>

          <section class="cuenta-panel" data-panel-compras hidden>
            <div class="compras-page-card" data-compras-page>
              <div class="co-loading" data-compras-loading>
                <div class="loading-spinner"></div>
                <p>Cargando tus compras...</p>
              </div>
            </div>
          </section>

          <section class="cuenta-panel" data-panel-medios hidden>
            <div class="compras-page-card" data-medios-page>
              <div class="co-loading" data-medios-loading>
                <div class="loading-spinner"></div>
                <p>Cargando...</p>
              </div>
            </div>
          </section>
        </div>
      </div>
    </section>

    <section class="products-hero text-block account-page-card" data-login-page hidden>
      <h3>Iniciar sesión</h3>
      <form class="auth-form" data-page-login-form>
        <label for="page-login-identifier">Usuario o email</label>
        <input id="page-login-identifier" name="identifier" type="text" required />

        <label for="page-login-password">Password</label>
        <input id="page-login-password" name="password" type="password" required />

        <button class="btn" type="submit">Iniciar sesión</button>
      </form>
    </section>
  </main>
</BaseLayout>

<style is:global>
  .cuenta-layout {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 28px;
    align-items: start;
  }

  .cuenta-sidebar {
    display: flex;
    flex-direction: column;
    gap: 4px;
    position: sticky;
    top: 24px;
  }

  .cuenta-tab {
    display: block;
    width: 100%;
    padding: 12px 16px;
    border: none;
    border-radius: 10px;
    background: transparent;
    font: inherit;
    font-size: 1.05rem;
    font-weight: 600;
    color: #4a423d;
    text-align: left;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .cuenta-tab:hover {
    background: #f0ece7;
  }

  .cuenta-tab--active {
    background: #dfd3c8;
    color: #243233;
  }

  .cuenta-content {
    min-height: 300px;
  }

  .cuenta-panel {
    animation: co-fade-up 0.25s ease both;
  }

  .compras-page-card {
    background: #fffaf5;
    border: 1px solid #e8dfd7;
    border-radius: 14px;
    padding: 28px;
  }

  .co-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 60px 20px;
    text-align: center;
    color: #6a5f55;
  }

  .co-loading p {
    margin: 0;
    font-family: 'PT Serif', serif;
    font-style: italic;
  }

  .compras-empty {
    text-align: center;
    padding: 60px 20px;
  }

  .compras-empty__icon {
    width: 48px;
    height: 48px;
    margin: 0 auto 16px;
    color: #c4b8ae;
  }

  .compras-empty p {
    margin: 0;
    font-size: 1.1rem;
    color: #6a5f55;
  }

  .compras-lista {
    display: grid;
    gap: 20px;
  }

  .compra-card {
    background: #ffffff;
    border: 1px solid #ece3dc;
    border-radius: 14px;
    padding: 20px;
    transition: box-shadow 0.2s ease;
  }

  .compra-card:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.04);
  }

  .compra-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
    padding-bottom: 12px;
    border-bottom: 1px solid #f2ece7;
    flex-wrap: wrap;
  }

  .compra-header__meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .compra-header__id {
    font-weight: 700;
    color: #243233;
    font-size: 1rem;
  }

  .compra-header__fecha {
    font-size: 0.85rem;
    color: #8a7f75;
  }

  .compra-header__total {
    font-weight: 700;
    color: #243233;
    font-size: 1.1rem;
  }

  .compra-badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .compra-badge--completada {
    background: #d4edda;
    color: #155724;
  }

  .compra-badge--pendiente {
    background: #fff3cd;
    color: #856404;
  }

  .compra-badge--rechazada {
    background: #f8d7da;
    color: #721c24;
  }

  .compra-badge--cancelada {
    background: #e2e3e5;
    color: #383d41;
  }

  .compra-items {
    display: grid;
    gap: 8px;
  }

  .compra-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 12px;
    background: #fffdfb;
    border: 1px solid #f2ece7;
    border-radius: 10px;
  }

  .compra-item__thumb {
    width: 48px;
    height: 48px;
    border-radius: 6px;
    overflow: hidden;
    background: #f0ece7;
    flex-shrink: 0;
  }

  .compra-item__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .compra-item__info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .compra-item__name {
    font-weight: 700;
    color: #243233;
    font-size: 0.95rem;
  }

  .compra-item__price {
    font-size: 0.85rem;
    color: #6a5f55;
  }

  .compra-item__download .btn {
    padding: 6px 14px;
    font-size: 0.85rem;
  }

  @media (max-width: 700px) {
    .cuenta-layout {
      grid-template-columns: 1fr;
    }

    .cuenta-sidebar {
      flex-direction: row;
      position: static;
    }

    .cuenta-tab {
      text-align: center;
      font-size: 0.95rem;
      padding: 10px 12px;
    }

    .compra-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<script>
  const flowResultBanner = document.querySelector('[data-flow-result]')
  const flowParam = new URLSearchParams(window.location.search).get('flow')
  if (flowParam && flowResultBanner) {
    const messages = {
      completada: { text: 'Pago recibido exitosamente. Tus productos están listos para descargar.', type: 'success' },
      rechazada: { text: 'El pago fue rechazado. Intenta nuevamente o usa transferencia bancaria.', type: 'error' },
      cancelada: { text: 'El pago fue cancelado.', type: 'info' },
      procesando: { text: 'Pago recibido. Estamos verificando la transacción, en unos momentos estarán disponibles tus productos.', type: 'info' },
      pendiente: { text: 'El pago está siendo procesado. Recibirás una confirmación pronto.', type: 'info' },
    }
    const info = messages[flowParam] || { text: 'Estado de pago: ' + flowParam, type: 'info' }
    flowResultBanner.textContent = info.text
    flowResultBanner.className = 'flow-result-banner flow-result-banner--' + info.type
    flowResultBanner.removeAttribute('hidden')
    const newUrl = window.location.pathname + window.location.hash
    window.history.replaceState({}, '', newUrl)
  }

  const cuentaLayout = document.querySelector('[data-cuenta-layout]')
  const accountContainer = document.querySelector('[data-account-page]')
  const loginContainer = document.querySelector('[data-login-page]')
  const pageLoginForm = document.querySelector('[data-page-login-form]')
  const comprasPage = document.querySelector('[data-compras-page]')
  const comprasLoading = document.querySelector('[data-compras-loading]')
  const mediosPage = document.querySelector('[data-medios-page]')
  const mediosLoading = document.querySelector('[data-medios-loading]')

  const tabPerfil = document.querySelector('[data-tab-perfil]')
  const tabCompras = document.querySelector('[data-tab-compras]')
  const tabMedios = document.querySelector('[data-tab-medios]')
  const panelPerfil = document.querySelector('[data-panel-perfil]')
  const panelCompras = document.querySelector('[data-panel-compras]')
  const panelMedios = document.querySelector('[data-panel-medios]')

  const backendOrigin = window.location.origin
  const backendUrl = (path) => `${backendOrigin}${path}`

  const formatPrice = (price) => {
    if (price == null) return '$0'
    return '$' + String(price).replace(/\B(?=(\d{3})+(?!\d))/g, '.')
  }

  const formatDate = (iso) => {
    if (!iso) return ''
    const d = new Date(iso)
    return d.toLocaleDateString('es-CL', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })
  }

  const estadoLabels = {
    completada: 'Completada',
    pendiente: 'Pendiente',
    rechazada: 'Rechazada',
    cancelada: 'Cancelada',
  }

  // ── TAB SWITCHING ──

  const switchTab = (tab) => {
    [tabPerfil, tabCompras, tabMedios].forEach(t => t?.classList.remove('cuenta-tab--active'))
    tab?.classList.add('cuenta-tab--active')

    panelPerfil?.setAttribute('hidden', '')
    panelCompras?.setAttribute('hidden', '')
    panelMedios?.setAttribute('hidden', '')

    if (tab === tabPerfil) panelPerfil?.removeAttribute('hidden')
    if (tab === tabCompras) {
      panelCompras?.removeAttribute('hidden')
      loadCompras()
    }
    if (tab === tabMedios) {
      panelMedios?.removeAttribute('hidden')
      loadMedios()
    }
  }

  tabPerfil?.addEventListener('click', () => switchTab(tabPerfil))
  tabCompras?.addEventListener('click', () => switchTab(tabCompras))
  tabMedios?.addEventListener('click', () => switchTab(tabMedios))

  // ── PROFILE ──

  const renderAccount = (user) => {
    if (!accountContainer) return
    accountContainer.innerHTML = `
      <h3>Datos de cuenta</h3>
      <form class="auth-form" data-page-account-form>
        <label for="page-account-username">Nombre de usuario</label>
        <input id="page-account-username" type="text" value="${user.username || ''}" disabled />

        <label for="page-account-email">Email</label>
        <input id="page-account-email" type="email" value="${user.email || ''}" disabled />

        <label for="page-account-nombre">Nombre</label>
        <input id="page-account-nombre" name="nombre" type="text" value="${user.nombre || ''}" required />

        <label for="page-account-apellido">Apellido</label>
        <input id="page-account-apellido" name="apellido" type="text" value="${user.apellido || ''}" required />

        <label for="page-account-pais">País</label>
        <select id="page-account-pais" name="pais" required>
          <option value="">Selecciona un país</option>
          ${countries.map(c =>
            `<option value="${c}"${user.pais === c ? ' selected' : ''}>${c}</option>`
          ).join('')}
        </select>

        <label for="page-account-password">Nueva contraseña (opcional)</label>
        <input id="page-account-password" name="password" type="password" minlength="8" />

        <label for="page-account-password-confirm">Confirmar nueva contraseña</label>
        <input id="page-account-password-confirm" name="password_confirm" type="password" minlength="8" />

        <button class="btn" type="submit">Guardar cambios</button>
      </form>
      <p class="auth-message" data-page-account-message></p>
    `

    const form = accountContainer.querySelector('[data-page-account-form]')
    const message = accountContainer.querySelector('[data-page-account-message]')

    form?.addEventListener('submit', async (event) => {
      event.preventDefault()
      const formData = new FormData(form)
      const nombre = String(formData.get('nombre') || '').trim()
      const apellido = String(formData.get('apellido') || '').trim()
      const pais = String(formData.get('pais') || '').trim()
      const password = String(formData.get('password') || '')
      const passwordConfirm = String(formData.get('password_confirm') || '')

      if (!nombre || !apellido || !pais) {
        const errorMessage = 'Nombre, apellido y país son obligatorios.'
        message.textContent = errorMessage
        message.classList.add('error')
        await (window.showStyledAlert
          ? window.showStyledAlert('Error al actualizar cuenta\n' + errorMessage, 'Error', 'danger')
          : Promise.resolve(alert('Error al actualizar cuenta\n' + errorMessage)))
        return
      }

      if ((password || passwordConfirm) && password !== passwordConfirm) {
        const errorMessage = 'Las contraseñas no coinciden.'
        message.textContent = errorMessage
        message.classList.add('error')
        await (window.showStyledAlert
          ? window.showStyledAlert('Error al actualizar cuenta\n' + errorMessage, 'Error', 'danger')
          : Promise.resolve(alert('Error al actualizar cuenta\n' + errorMessage)))
        return
      }

      const wantsSave = await (window.showStyledConfirm
        ? window.showStyledConfirm('¿Confirmas actualizar tu cuenta?\n\nNombre: ' + nombre + '\nApellido: ' + apellido + '\nPaís: ' + pais + (password ? '\nContraseña: (se actualizará)' : ''))
        : Promise.resolve(confirm('¿Confirmas actualizar tu cuenta?\n\nNombre: ' + nombre + '\nApellido: ' + apellido + '\nPaís: ' + pais + (password ? '\nContraseña: (se actualizará)' : ''))))

      if (!wantsSave) return

      const payload = new URLSearchParams()
      payload.append('nombre', nombre)
      payload.append('apellido', apellido)
      payload.append('pais', pais)
      payload.append('password', password)
      payload.append('password_confirm', passwordConfirm)

      const response = await fetch(backendUrl('/api/auth/account/update/'), {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: payload,
      })

      const data = response.ok ? await (window.safeFetchJson?.(response) ?? response.json()) : {}
      if (!response.ok || !data.ok) {
        const errorMessage = data.message || 'No se pudo actualizar la cuenta.'
        message.textContent = errorMessage
        message.classList.add('error')
        await (window.showStyledAlert
          ? window.showStyledAlert('Error al actualizar cuenta\n' + errorMessage, 'Error', 'danger')
          : Promise.resolve(alert('Error al actualizar cuenta\n' + errorMessage)))
        return
      }

      message.textContent = 'Cuenta actualizada correctamente.'
      message.classList.remove('error')
      renderAccount(data.user)
      await (window.showStyledAlert
        ? window.showStyledAlert('Cuenta actualizada\nNombre: ' + nombre + '\nApellido: ' + apellido + '\nPaís: ' + pais, 'Éxito', 'success')
        : Promise.resolve(alert('Cuenta actualizada\nNombre: ' + nombre + '\nApellido: ' + apellido + '\nPaís: ' + pais)))
    })
  }

  // ── PURCHASES ──

  const renderCompras = (data) => {
    if (!comprasPage) return

    if (!data.ordenes || data.ordenes.length === 0) {
      comprasPage.innerHTML = `
        <div class="compras-empty">
          <svg class="compras-empty__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
          <p>No has realizado compras aún.</p>
        </div>
      `
      return
    }

    const ordenesHtml = data.ordenes.map((orden) => {
      const itemsHtml = (orden.items || []).map((item) => {
        const imgHtml = item.imagen
          ? `<img src="${item.imagen}" alt="${item.nombre}" width="48" height="48" loading="lazy" />`
          : `<div class="compra-item__thumb-placeholder"></div>`
        const downloadHtml = orden.estado === 'completada' && item.descarga_token
          ? (() => {
              const expDate = new Date(item.expira_en)
              const now = new Date()
              const expired = expDate <= now
              const dateStr = expDate.toLocaleDateString('es-CL', { year: 'numeric', month: 'short', day: 'numeric' })
              if (expired) {
                return `<div class="compra-item__download" style="text-align:center"><span class="btn btn-secondary compra-item__download" style="opacity:0.4;pointer-events:none">Expirado</span><br><span style="font-size:0.75rem;color:#8a7f75">Venció el ${dateStr}</span></div>`
              }
              return `<div class="compra-item__download" style="text-align:center"><a href="${backendUrl('/api/descargas/' + item.descarga_token + '/')}" class="btn btn-secondary compra-item__download">Descargar</a><br><span style="font-size:0.75rem;color:#8a7f75">Vence el ${dateStr}</span></div>`
            })()
          : ''
        return `
          <div class="compra-item">
            <div class="compra-item__thumb">${imgHtml}</div>
            <div class="compra-item__info">
              <span class="compra-item__name">${item.nombre}</span>
              <span class="compra-item__price">${formatPrice(item.precio)}</span>
            </div>
            ${downloadHtml}
          </div>
        `
      }).join('')

      return `
        <div class="compra-card">
          <div class="compra-header">
            <div class="compra-header__meta">
              <span class="compra-header__id">Orden #${orden.id}</span>
              <span class="compra-header__fecha">${formatDate(orden.creada)}</span>
              <span class="compra-badge compra-badge--${orden.estado}">${estadoLabels[orden.estado] || orden.estado}</span>
            </div>
            <span class="compra-header__total">${formatPrice(orden.total)}</span>
          </div>
          <div class="compra-items">${itemsHtml}</div>
        </div>
      `
    }).join('')

    comprasPage.innerHTML = `<div class="compras-lista">${ordenesHtml}</div>`
  }

  const loadCompras = async () => {
    if (!comprasPage || !comprasLoading) return
    comprasLoading?.removeAttribute('hidden')

    try {
      const res = await fetch(backendUrl('/api/compras/'), { credentials: 'include' })
      if (!res.ok) {
        comprasPage.innerHTML = `<div class="compras-empty"><p>Error al cargar tus compras.</p></div>`
        return
      }
      const data = await res.json()
      if (data.ok) {
        comprasLoading?.setAttribute('hidden', '')
        renderCompras(data)
      }
    } catch {
      comprasPage.innerHTML = `<div class="compras-empty"><p>Error de conexión.</p></div>`
    }
  }

  const loadMedios = async () => {
    if (!mediosPage || !mediosLoading) return
    mediosLoading?.removeAttribute('hidden')

    try {
      const res = await fetch(backendUrl('/api/flow/medios-pago/'), { credentials: 'include' })
      const data = await res.json()
      if (data.ok && data.tarjeta) {
        const t = data.tarjeta
        mediosPage.innerHTML = `
          <div class="compras-empty" style="text-align:left;padding:20px 0">
            <div class="compra-card" style="margin-bottom:16px">
              <div class="compra-header">
                <div class="compra-header__meta">
                  <span class="compra-header__id">${t.tipo || ''} terminada en ${t.ultimos_cuatro || '****'}</span>
                </div>
              </div>
              <div class="compra-items">
                <p style="margin:0;color:#6a5f55">Banco: ${t.banco || '—'}</p>
              </div>
            </div>
            <button class="btn btn-secondary" type="button" id="btn-eliminar-tarjeta" style="margin-top:8px">Eliminar tarjeta</button>
          </div>
        `
        document.getElementById('btn-eliminar-tarjeta')?.addEventListener('click', async () => {
          const confirmed = await (window.showStyledConfirm
            ? window.showStyledConfirm('¿Eliminar tarjeta guardada?')
            : Promise.resolve(confirm('¿Eliminar tarjeta guardada?')))
          if (!confirmed) return
          const delRes = await fetch(backendUrl('/api/flow/unregister-card/'), { method: 'POST', credentials: 'include' })
          const delData = await delRes.json()
          if (delData.ok) {
            loadMedios()
            await (window.showStyledAlert
              ? window.showStyledAlert('Tarjeta eliminada.', 'Éxito', 'success')
              : Promise.resolve(alert('Tarjeta eliminada.')))
          }
        })
      } else {
        mediosPage.innerHTML = `<div class="compras-empty"><p>No tienes tarjetas guardadas.</p><p style="font-size:0.9rem;color:#8a7f75;margin-top:8px">Al pagar con Flow puedes marcar "Guardar tarjeta" para agilizar futuras compras.</p></div>`
      }
      mediosLoading?.setAttribute('hidden', '')
    } catch {
      mediosPage.innerHTML = `<div class="compras-empty"><p>Error de conexión.</p></div>`
    }
  }

  // ── AUTH SESSION ──

  const loadSession = async () => {
    const response = await fetch(backendUrl('/api/auth/session/'), { credentials: 'include' })
    if (!response.ok) return
    const data = await response.json()

    if (!data.authenticated) {
      cuentaLayout?.setAttribute('hidden', '')
      loginContainer?.removeAttribute('hidden')
      return
    }

    loginContainer?.setAttribute('hidden', '')
    cuentaLayout?.removeAttribute('hidden')
    renderAccount(data.user)
  }

  pageLoginForm?.addEventListener('submit', async (event) => {
    event.preventDefault()
    const formData = new FormData(pageLoginForm)
    const identifier = String(formData.get('identifier') || '').trim()
    const password = String(formData.get('password') || '')

    const payload = new URLSearchParams()
    payload.append('username', identifier)
    payload.append('password', password)

    const response = await fetch(backendUrl('/api/auth/login/'), {
      method: 'POST',
      credentials: 'include',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: payload,
    })

    if (!response.ok) {
      const data = await window.safeFetchJson
        ? window.safeFetchJson(response)
        : response.json().catch(() => ({ message: 'No se pudo iniciar sesión.' }))
      const msg = data?.message || 'No se pudo iniciar sesión.'
      await (window.showStyledAlert
        ? window.showStyledAlert(msg, 'Error', 'danger')
        : Promise.resolve(alert(msg)))
      return
    }
    pageLoginForm.reset()
    loadSession()
    await (window.showStyledAlert
      ? window.showStyledAlert('Sesión iniciada correctamente.', 'Éxito', 'success')
      : Promise.resolve(alert('Sesión iniciada correctamente.')))
  })

  loadSession()

  // ── COUNTRIES LIST (for profile form) ──
