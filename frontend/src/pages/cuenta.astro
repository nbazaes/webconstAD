          <option value="Vanuatu"${user.pais === 'Vanuatu' ? ' selected' : ''}>Vanuatu</option>
          <option value="Vaticano"${user.pais === 'Vaticano' ? ' selected' : ''}>Vaticano</option>
          <option value="Venezuela"${user.pais === 'Venezuela' ? ' selected' : ''}>Venezuela</option>
          <option value="Vietnam"${user.pais === 'Vietnam' ? ' selected' : ''}>Vietnam</option>
          <option value="Yemen"${user.pais === 'Yemen' ? ' selected' : ''}>Yemen</option>
          <option value="Yibuti"${user.pais === 'Yibuti' ? ' selected' : ''}>Yibuti</option>
          <option value="Zambia"${user.pais === 'Zambia' ? ' selected' : ''}>Zambia</option>
          <option value="Zimbabue"${user.pais === 'Zimbabue' ? ' selected' : ''}>Zimbabue</option>
        </select>

        <label for="page-account-password">Nueva contraseña (opcional)</label>
        <input id="page-account-password" name="password" type="password" minlength="8" />

        <label for="page-account-password-confirm">Confirmar nueva contraseña</label>
        <input id="page-account-password-confirm" name="password_confirm" type="password" minlength="8" />

        <button class="btn" type="submit">Guardar cambios</button>
      </form>
      <p class="auth-message" data-page-account-message></p>
    `

    const form = accountContainer.querySelector('[data-page-account-form]')
    const message = accountContainer.querySelector('[data-page-account-message]')

    form?.addEventListener('submit', async (event) => {
      event.preventDefault()
      const formData = new FormData(form)
      const nombre = String(formData.get('nombre') || '').trim()
      const apellido = String(formData.get('apellido') || '').trim()
      const pais = String(formData.get('pais') || '').trim()
      const password = String(formData.get('password') || '')
      const passwordConfirm = String(formData.get('password_confirm') || '')

      if (!nombre || !apellido || !pais) {
        const errorMessage = 'Nombre, apellido y país son obligatorios.'
        message.textContent = errorMessage
        message.classList.add('error')
        await (window.showStyledAlert
          ? window.showStyledAlert(`Error al actualizar cuenta\n${errorMessage}`, 'Error', 'danger')
          : Promise.resolve(alert(`Error al actualizar cuenta\n${errorMessage}`)))
        return
      }

      if ((password || passwordConfirm) && password !== passwordConfirm) {
        const errorMessage = 'Las contraseñas no coinciden.'
        message.textContent = errorMessage
        message.classList.add('error')
        await (window.showStyledAlert
          ? window.showStyledAlert(`Error al actualizar cuenta\n${errorMessage}`, 'Error', 'danger')
          : Promise.resolve(alert(`Error al actualizar cuenta\n${errorMessage}`)))
        return
      }

      const wantsSave = await (window.showStyledConfirm
        ? window.showStyledConfirm(`¿Confirmas actualizar tu cuenta?\n\nNombre: ${nombre}\nApellido: ${apellido}\nPaís: ${pais}${password ? '\nContraseña: (se actualizará)' : ''}`)
        : Promise.resolve(confirm(`¿Confirmas actualizar tu cuenta?\n\nNombre: ${nombre}\nApellido: ${apellido}\nPaís: ${pais}${password ? '\nContraseña: (se actualizará)' : ''}`)))

      if (!wantsSave) {
        return
      }

      const payload = new URLSearchParams()
      payload.append('nombre', nombre)
      payload.append('apellido', apellido)
      payload.append('pais', pais)
      payload.append('password', password)
      payload.append('password_confirm', passwordConfirm)

      const response = await fetch(backendUrl('/api/auth/account/update/'), {
        method: 'POST',
        credentials: 'include',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: payload,
      })

      const data = response.ok ? await (window.safeFetchJson?.(response) ?? response.json()) : {}
      if (!response.ok || !data.ok) {
        const errorMessage = data.message || 'No se pudo actualizar la cuenta.'
        message.textContent = errorMessage
        message.classList.add('error')
        await (window.showStyledAlert
          ? window.showStyledAlert(`Error al actualizar cuenta\n${errorMessage}`, 'Error', 'danger')
          : Promise.resolve(alert(`Error al actualizar cuenta\n${errorMessage}`)))
        return
      }

      message.textContent = 'Cuenta actualizada correctamente.'
      message.classList.remove('error')
      renderAccount(data.user)
      await (window.showStyledAlert
        ? window.showStyledAlert(`Cuenta actualizada\nNombre: ${nombre}\nApellido: ${apellido}\nPaís: ${pais}`, 'Éxito', 'success')
        : Promise.resolve(alert(`Cuenta actualizada\nNombre: ${nombre}\nApellido: ${apellido}\nPaís: ${pais}`)))
    })
  }

  const loadSession = async () => {
    const response = await fetch(backendUrl('/api/auth/session/'), { credentials: 'include' })
    if (!response.ok) return
    const data = await response.json()

    if (!data.authenticated) {
      accountContainer?.setAttribute('hidden', '')
      loginContainer?.removeAttribute('hidden')
      return
    }

    loginContainer?.setAttribute('hidden', '')
    accountContainer?.removeAttribute('hidden')
    renderAccount(data.user)
  }

  pageLoginForm?.addEventListener('submit', async (event) => {
    event.preventDefault()
    const formData = new FormData(pageLoginForm)
    const identifier = String(formData.get('identifier') || '').trim()
    const password = String(formData.get('password') || '')

    const payload = new URLSearchParams()
    payload.append('username', identifier)
    payload.append('password', password)

    const response = await fetch(backendUrl('/api/auth/login/'), {
      method: 'POST',
      credentials: 'include',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
      },
      body: payload,
    })

    if (!response.ok) {
      const data = await window.safeFetchJson
        ? window.safeFetchJson(response)
        : response.json().catch(() => ({ message: 'No se pudo iniciar sesión.' }))
      const msg = data?.message || 'No se pudo iniciar sesión.'
      await (window.showStyledAlert
        ? window.showStyledAlert(msg, 'Error', 'danger')
        : Promise.resolve(alert(msg)))
      return
    }
    pageLoginForm.reset()
    loadSession()
    await (window.showStyledAlert
      ? window.showStyledAlert('Sesión iniciada correctamente.', 'Éxito', 'success')
      : Promise.resolve(alert('Sesión iniciada correctamente.')))
  })

  loadSession()
</script>
