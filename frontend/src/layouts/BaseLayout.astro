    <script>
      (function() {
        const cartToggle = document.querySelector('[data-cart-toggle]')
        const cartDrawer = document.querySelector('[data-cart-drawer]')
        const cartOverlay = document.querySelector('[data-cart-overlay]')
        const cartClosers = document.querySelectorAll('[data-cart-close]')
        const cartBadge = document.querySelector('[data-cart-badge]')
        const cartItems = document.querySelector('[data-cart-items]')
        const cartEmpty = document.querySelector('[data-cart-empty]')
        const cartFooter = document.querySelector('[data-cart-footer]')
        const cartTotal = document.querySelector('[data-cart-total]')
        const checkoutBtn = document.querySelector('[data-cart-checkout]')
        const checkoutBtnFlow = document.querySelector('[data-cart-checkout-flow]')


        let peekTimeout = null

        const backendOrigin = window.location.origin
        const backendUrl = (path) => `${backendOrigin}${path}`

        const formatPrice = (price) => {
          if (price == null) return '$0'
          return '$' + String(price).replace(/\B(?=(\d{3})+(?!\d))/g, ' ')
        }

        const DRAWER_TRANSITION_MS = 350

        const showDrawer = () => {
          cartDrawer?.classList.add('open')
          cartDrawer?.style.removeProperty('visibility')
        }

        const hideDrawer = () => {
          cartDrawer?.classList.remove('open')
          setTimeout(() => {
            if (!cartDrawer?.classList.contains('open')) {
              cartDrawer.style.visibility = 'hidden'
            }
          }, DRAWER_TRANSITION_MS)
        }

        const openCart = (withOverlay = true) => {
          if (peekTimeout) {
            clearTimeout(peekTimeout)
            peekTimeout = null
          }
          showDrawer()
          if (withOverlay) {
            cartOverlay?.removeAttribute('hidden')
            document.body.classList.add('cart-open')
          }
        }

        const closeCart = () => {
          hideDrawer()
          cartOverlay?.setAttribute('hidden', '')
          document.body.classList.remove('cart-open')
        }

        const updateBadge = (count) => {
          if (!cartBadge) return
          if (count > 0) {
            cartBadge.textContent = count > 99 ? '99+' : String(count)
            cartBadge.removeAttribute('hidden')
          } else {
            cartBadge.setAttribute('hidden', '')
          }
        }

        window.peekCart = function() {
          if (peekTimeout) clearTimeout(peekTimeout)
          showDrawer()
          peekTimeout = setTimeout(() => {
            hideDrawer()
            peekTimeout = null
          }, 1500)
        }

        const renderCart = (data) => {
          if (!cartItems || !cartEmpty || !cartFooter || !cartTotal) return

          if (!data || !data.items || data.items.length === 0) {
            cartItems.setAttribute('hidden', '')
            cartEmpty.removeAttribute('hidden')
            cartFooter.setAttribute('hidden', '')
            updateBadge(0)
            return
          }

          cartEmpty.setAttribute('hidden', '')
          cartItems.removeAttribute('hidden')
          cartFooter.removeAttribute('hidden')

          cartItems.innerHTML = data.items.map((item) => {
            const imgHtml = item.producto.imagen
              ? `<img src="${item.producto.imagen}" alt="${item.producto.nombre}" width="60" height="60" loading="lazy" />`
              : `<div class="cart-item__thumb-placeholder"></div>`
            return `
              <div class="cart-item" data-cart-item-id="${item.id}">
                <div class="cart-item__thumb">${imgHtml}</div>
                <div class="cart-item__info">
                  <a href="/productos/${item.producto.slug}/" class="cart-item__name">${item.producto.nombre}</a>
                  <span class="cart-item__price">${formatPrice(item.producto.precio)}</span>
                </div>
                <button class="cart-item__remove" type="button" data-remove-item="${item.id}" aria-label="Eliminar ${item.producto.nombre}">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                </button>
              </div>
            `
          }).join('')

          cartTotal.textContent = formatPrice(data.total)
          updateBadge(data.count)

          cartItems.querySelectorAll('[data-remove-item]').forEach((btn) => {
            btn.addEventListener('click', async () => {
              const itemId = btn.dataset.removeItem
              const confirmed = await window.showStyledConfirm?.('¿Eliminar este producto del carrito?')
              if (!confirmed) return
              try {
                await fetch(backendUrl(`/api/cart/items/${itemId}/`), {
                  method: 'DELETE',
                  credentials: 'include',
                })
                document.dispatchEvent(new CustomEvent('cart:updated'))
              } catch (e) {
                console.error('Error removing item', e)
              }
            })
          })
        }

        const fetchCart = async () => {
          try {
            const sessionRes = await fetch(backendUrl('/api/auth/session/'), { credentials: 'include' })
            const session = await sessionRes.json()
            if (!session.authenticated) {
              renderCart({ items: [], count: 0, total: 0 })
              return
            }

            const res = await fetch(backendUrl('/api/cart/'), { credentials: 'include' })
            const data = await res.json()
            renderCart(data)
          } catch {
            renderCart({ items: [], count: 0, total: 0 })
          }
        }


        cartToggle?.addEventListener('click', async () => {
          await fetchCart()
          openCart()
        })

        cartClosers.forEach((btn) => btn.addEventListener('click', closeCart))

        cartOverlay?.addEventListener('click', closeCart)

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && cartDrawer?.classList.contains('open')) {
            closeCart()
          }
        })

        document.addEventListener('cart:updated', fetchCart)

        checkoutBtn?.addEventListener('click', () => {
          window.location.href = '/checkout/'
        })

        checkoutBtnFlow?.addEventListener('click', () => {
          window.location.href = '/checkout/'
        })

        fetchCart()
      })()
    </script>
  </body>
</html>
