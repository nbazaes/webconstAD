---
import '../styles/global.css'
import { Icon } from 'astro-icon/components' 

const { title = 'Constant Archivos Digitales', description = 'Archivos digitales para imprimir o dibujar — cuadernas, libretas, novelas gráficas y más.', page = 'inicio', image = '/static/web/assets/logo.webp' } = Astro.props
const currentYear = new Date().getFullYear()
const rawVersion = (import.meta.env.PUBLIC_APP_VERSION || '').trim()
const appVersion = rawVersion ? (rawVersion.startsWith('v') ? rawVersion : `v${rawVersion}`) : 'dev'
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://constantdigitales.com'
const canonical = new URL(Astro.url.pathname, siteUrl).href
const navItems = [
  { id: 'inicio', label: 'Inicio', href: '/' },
  { id: 'productos', label: 'Productos', href: '/productos/' },
  { id: 'uso', label: 'Uso', href: '/uso/' },
  // { id: 'canva', label: 'Canva', href: '/canva/' },
  { id: 'gratis', label: 'Gratis', href: '/gratis/' },
  { id: 'cuenta', label: 'Cuenta', href: '/cuenta/' },
  { id: 'contacto', label: 'Contacto', href: '/contacto/' },
]

const asset = (path) => `/${path}`
---

<!doctype html>
<html lang="es">
 
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/static/web/assets/favicon.svg?v=3" />
    <link rel="icon" type="image/x-icon" href="/static/web/assets/favicon.ico?v=3" sizes="any" />
    <link rel="shortcut icon" href="/static/web/assets/favicon.svg?v=3" />
    <link rel="apple-touch-icon" href="/static/web/assets/favicon.svg?v=3" />
    <meta name="msapplication-TileColor" content="#ffffff" />
    <meta name="theme-color" content="#ffffff" />

    <!-- Preconnect to font origins for faster cross-origin requests -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Google Fonts with font-display:swap -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Great+Vibes&family=PT+Serif:ital,wght@0,400;0,700;1,400;1,700&display=swap"
    />

    <!-- SEO -->
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, siteUrl).href} />
    <meta property="og:locale" content="es_CL" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- CSRF protection for API calls -->
    <script defer src="/csrf.js"></script>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Constant Archivos Digitales",
      "url": siteUrl,
      "logo": new URL('/static/web/assets/logo.webp', siteUrl).href,
      "description": description,
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer service",
        "url": `${siteUrl}/contacto/`
      }
    })} />
  </head>
  <body
    style={`--ribbon-unsel: url('${asset('static/web/assets/ribbon-unsel.svg')}'); --ribbon-sel: url('${asset('static/web/assets/ribbon-sel.svg')}')`}
  >
    <div class="page-wrap">
      <img src={asset('static/web/assets/g51.svg')} alt="" class="decor decor-top-right" aria-hidden="true" width="550" height="155" />
      <img src={asset('static/web/assets/g45.webp')} alt="" class="decor decor-leaf-left" aria-hidden="true" width="80" height="140" />

      <header class="site-header">
        <a href="/" class="home-link">
          <div class="brand">
            <img src={asset('static/web/assets/logo.webp')} alt="Logo" class="logo" width="110" height="110" fetchpriority="high" />
            <div class="site-title">
              <img src={asset('static/web/assets/g345.webp')} alt="Constant Archivos Digitales" width="190" height="89" />
            </div>
          </div>
        </a>
        <div class="header-actions">
          <button class="cart-toggle" type="button" aria-label="Abrir carrito" data-cart-toggle>
            <svg class="cart-heart" viewBox="0 0 24 24" fill="#fff" aria-hidden="true">
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
            </svg>
            <Icon name="lucide:shopping-cart" class="cart-icon" />
            <span class="cart-badge" data-cart-badge hidden>0</span>
          </button>
          <button class="hamburger" aria-label="Abrir menu" aria-expanded="false" data-menu-toggle>
            <span></span><span></span><span></span>
          </button>
        </div>
      </header>

      <nav class="mobile-nav" aria-label="Navegacion movil" data-mobile-nav>
        <ul>
          {navItems.map((item) => (
            <li>
              <a href={item.href} data-nav-id={item.id} class={page === item.id ? 'active' : ''} aria-current={page === item.id ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))}
          <li>
            <a href="#" data-auth-tab>Iniciar sesión</a>
          </li>
          <li data-publish-nav hidden>
            <a href="/publicar/" data-publish-tab class={page === 'publicar' ? 'active' : ''} aria-current={page === 'publicar' ? 'page' : undefined}>Publicar</a>
          </li>
        </ul>
      </nav>

      <aside class="side-nav">
        <ul>
          {navItems.map((item) => (
            <li>
              <a href={item.href} data-nav-id={item.id} class={page === item.id ? 'active' : ''} aria-current={page === item.id ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))}
          <li>
            <a href="#" data-auth-tab>Iniciar sesión</a>
          </li>
          <li data-publish-nav hidden>
            <a href="/publicar/" data-publish-tab class={page === 'publicar' ? 'active' : ''} aria-current={page === 'publicar' ? 'page' : undefined}>Publicar</a>
          </li>
        </ul>
      </aside>

      <slot />
    </div>

    <div class="auth-modal" data-auth-modal hidden>
      <div class="auth-modal__backdrop" data-auth-close></div>
      <div class="auth-modal__panel" role="dialog" aria-modal="true" aria-labelledby="auth-modal-title">
        <button class="auth-modal__close" type="button" aria-label="Cerrar" data-auth-close>×</button>

        <section data-auth-view="login">
          <h3 id="auth-modal-title">Iniciar sesión</h3>
          <form class="auth-form" data-login-form>
            <label for="login-identifier">Usuario o email</label>
            <input id="login-identifier" name="identifier" type="text" required />

            <label for="login-password">Contraseña</label>
            <input id="login-password" name="password" type="password" required />

            <button class="btn" type="submit">Iniciar sesión</button>
            <button class="auth-link" type="button" data-open-register>
              ¿No tienes cuenta de usuario? Regístrate aquí
            </button>
          </form>
        </section>

        <section data-auth-view="register" hidden>
          <h3 id="auth-modal-title">Registrarse</h3>
          <form class="auth-form" data-register-form>
            <label for="register-username">Nombre de usuario</label>
            <input id="register-username" name="username" type="text" required minlength="3" />

            <label for="register-email">Email</label>
            <input id="register-email" name="email" type="email" required />

            <label for="register-nombre">Nombre</label>
            <input id="register-nombre" name="nombre" type="text" required />

            <label for="register-apellido">Apellido</label>
            <input id="register-apellido" name="apellido" type="text" required />

            <label for="register-pais">País</label>
            <input id="register-pais" name="pais" type="text" required />

            <label for="register-password">Contraseña</label>
            <input id="register-password" name="password" type="password" required minlength="8" />

            <label for="register-password-confirm">Confirmar contraseña</label>
            <input id="register-password-confirm" name="password_confirm" type="password" required minlength="8" />

            <button class="btn" type="submit">Crear cuenta</button>
            <button class="auth-link" type="button" data-open-login>
              ¿Ya tienes cuenta? Inicia sesión aquí
            </button>
          </form>
        </section>

        <p class="auth-message" data-auth-message aria-live="polite"></p>
      </div>
    </div>

    <div class="confirm-modal" data-confirm-modal hidden>
      <div class="confirm-modal__backdrop" data-confirm-cancel></div>
      <div class="confirm-modal__panel" role="dialog" aria-modal="true" aria-labelledby="confirm-modal-title">
        <h3 id="confirm-modal-title">Confirmación</h3>
        <p data-confirm-message></p>
        <div class="confirm-modal__actions">
          <button class="btn btn-secondary" type="button" data-confirm-cancel>Cancelar</button>
          <button class="btn" type="button" data-confirm-accept>Aceptar</button>
        </div>
      </div>
    </div>

    <div class="cart-overlay" data-cart-overlay hidden></div>
    <aside class="cart-drawer" data-cart-drawer aria-label="Carrito de compras">
      <div class="cart-drawer__header">
        <h3 class="cart-drawer__title">Tu Carrito</h3>
        <button class="cart-drawer__close" type="button" aria-label="Cerrar carrito" data-cart-close>&times;</button>
      </div>
      <div class="cart-drawer__body" data-cart-body>
        <div class="cart-empty" data-cart-empty>
          <Icon name="lucide:shopping-bag" class="cart-empty-icon" />
          <p>Tu carrito está vacío</p>
        </div>
        <div class="cart-items" data-cart-items hidden></div>
      </div>
      <div class="cart-drawer__footer" data-cart-footer hidden>
        <div class="cart-total">
          <span>Total</span>
          <span class="cart-total__amount" data-cart-total>$0</span>
        </div>
        <button class="btn btn-cart-checkout" type="button" data-cart-checkout>Finalizar compra</button>
        <p class="cart-footer-note">Transferencia bancaria &mdash; te enviaremos los datos al finalizar</p>
      </div>
    </aside>

    <div class="checkout-modal" data-checkout-modal hidden>
      <div class="checkout-modal__backdrop" data-checkout-close></div>
      <div class="checkout-modal__panel" role="dialog" aria-modal="true" aria-labelledby="checkout-modal-title">
        <h3 id="checkout-modal-title">Finalizar compra</h3>
        <div class="checkout-modal__details" data-checkout-details>
          <p class="checkout-modal__lead">Transfiere a:</p>
          <dl class="checkout-modal__list" data-checkout-list></dl>
          <p class="checkout-modal__note">Envía el comprobante por Instagram a <a href="https://www.instagram.com/constantdesigns" target="_blank" rel="noreferrer">@constantdesigns</a>.</p>
        </div>
        <div class="checkout-modal__actions">
          <button class="btn" type="button" data-checkout-close>Entendido</button>
        </div>
      </div>
    </div>

    <footer class="site-footer">
      <img src={asset('static/web/assets/g40.svg')} alt="" class="decor decor-bottom-left" aria-hidden="true" width="380" height="299" loading="lazy" />
      <p>Constant Archivos Digitales © {currentYear} · {appVersion}</p>
      <p><a href="/politica-privacidad/">Política de privacidad</a></p>
      <p class="footer-credit">
        Web construida por <Icon name=lucide:github class='w-6 h-6 hover:text-pink-600'/> <a href="https://github.com/nbazaes">nbazaes</a>
      </p>
    </footer>

    <script defer src="/auth.js"></script>
    <script>
      (function() {
        const cartToggle = document.querySelector('[data-cart-toggle]')
        const cartDrawer = document.querySelector('[data-cart-drawer]')
        const cartOverlay = document.querySelector('[data-cart-overlay]')
        const cartClosers = document.querySelectorAll('[data-cart-close]')
        const cartBadge = document.querySelector('[data-cart-badge]')
        const cartItems = document.querySelector('[data-cart-items]')
        const cartEmpty = document.querySelector('[data-cart-empty]')
        const cartFooter = document.querySelector('[data-cart-footer]')
        const cartTotal = document.querySelector('[data-cart-total]')
        const checkoutBtn = document.querySelector('[data-cart-checkout]')

        const checkoutModal = document.querySelector('[data-checkout-modal]')
        const checkoutList = document.querySelector('[data-checkout-list]')
        const checkoutClosers = document.querySelectorAll('[data-checkout-close]')

        let peekTimeout = null

        const backendOrigin = window.location.origin
        const backendUrl = (path) => `${backendOrigin}${path}`

        const formatPrice = (price) => {
          if (price == null) return '$0'
          return '$' + String(price).replace(/\B(?=(\d{3})+(?!\d))/g, ' ')
        }

        const DRAWER_TRANSITION_MS = 350

        const showDrawer = () => {
          cartDrawer?.classList.add('open')
          cartDrawer?.style.removeProperty('visibility')
        }

        const hideDrawer = () => {
          cartDrawer?.classList.remove('open')
          setTimeout(() => {
            if (!cartDrawer?.classList.contains('open')) {
              cartDrawer.style.visibility = 'hidden'
            }
          }, DRAWER_TRANSITION_MS)
        }

        const openCart = (withOverlay = true) => {
          if (peekTimeout) {
            clearTimeout(peekTimeout)
            peekTimeout = null
          }
          showDrawer()
          if (withOverlay) {
            cartOverlay?.removeAttribute('hidden')
            document.body.classList.add('cart-open')
          }
        }

        const closeCart = () => {
          hideDrawer()
          cartOverlay?.setAttribute('hidden', '')
          document.body.classList.remove('cart-open')
        }

        const updateBadge = (count) => {
          if (!cartBadge) return
          if (count > 0) {
            cartBadge.textContent = count > 99 ? '99+' : String(count)
            cartBadge.removeAttribute('hidden')
          } else {
            cartBadge.setAttribute('hidden', '')
          }
        }

        window.peekCart = function() {
          if (peekTimeout) clearTimeout(peekTimeout)
          showDrawer()
          peekTimeout = setTimeout(() => {
            hideDrawer()
            peekTimeout = null
          }, 1500)
        }

        const renderCart = (data) => {
          if (!cartItems || !cartEmpty || !cartFooter || !cartTotal) return

          if (!data || !data.items || data.items.length === 0) {
            cartItems.setAttribute('hidden', '')
            cartEmpty.removeAttribute('hidden')
            cartFooter.setAttribute('hidden', '')
            updateBadge(0)
            return
          }

          cartEmpty.setAttribute('hidden', '')
          cartItems.removeAttribute('hidden')
          cartFooter.removeAttribute('hidden')

          cartItems.innerHTML = data.items.map((item) => {
            const imgHtml = item.producto.imagen
              ? `<img src="${item.producto.imagen}" alt="${item.producto.nombre}" width="60" height="60" loading="lazy" />`
              : `<div class="cart-item__thumb-placeholder"></div>`
            return `
              <div class="cart-item" data-cart-item-id="${item.id}">
                <div class="cart-item__thumb">${imgHtml}</div>
                <div class="cart-item__info">
                  <a href="/productos/${item.producto.slug}/" class="cart-item__name">${item.producto.nombre}</a>
                  <span class="cart-item__price">${formatPrice(item.producto.precio)}</span>
                </div>
                <button class="cart-item__remove" type="button" data-remove-item="${item.id}" aria-label="Eliminar ${item.producto.nombre}">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                </button>
              </div>
            `
          }).join('')

          cartTotal.textContent = formatPrice(data.total)
          updateBadge(data.count)

          cartItems.querySelectorAll('[data-remove-item]').forEach((btn) => {
            btn.addEventListener('click', async () => {
              const itemId = btn.dataset.removeItem
              const confirmed = await window.showStyledConfirm?.('¿Eliminar este producto del carrito?')
              if (!confirmed) return
              try {
                await fetch(backendUrl(`/api/cart/items/${itemId}/`), {
                  method: 'DELETE',
                  credentials: 'include',
                })
                document.dispatchEvent(new CustomEvent('cart:updated'))
              } catch (e) {
                console.error('Error removing item', e)
              }
            })
          })
        }

        const fetchCart = async () => {
          try {
            const sessionRes = await fetch(backendUrl('/api/auth/session/'), { credentials: 'include' })
            const session = await sessionRes.json()
            if (!session.authenticated) {
              renderCart({ items: [], count: 0, total: 0 })
              return
            }

            const res = await fetch(backendUrl('/api/cart/'), { credentials: 'include' })
            const data = await res.json()
            renderCart(data)
          } catch {
            renderCart({ items: [], count: 0, total: 0 })
          }
        }

        const showCheckoutModal = (details) => {
          if (!checkoutList || !checkoutModal) return
          const fields = [
            { label: 'Nombre completo', key: 'nombre_completo' },
            { label: 'RUT', key: 'rut' },
            { label: 'Email', key: 'email' },
            { label: 'Tipo de cuenta', key: 'tipo_cuenta' },
            { label: 'Banco', key: 'banco' },
            { label: 'Num. de cuenta', key: 'numero_cuenta' },
          ]
          checkoutList.innerHTML = fields
            .filter((f) => details[f.key])
            .map((f) => `<div><dt>${f.label}</dt><dd>${details[f.key]}</dd></div>`)
            .join('') || '<p>Datos de pago no disponibles.</p>'
          checkoutModal.removeAttribute('hidden')
        }

        const closeCheckoutModal = () => {
          checkoutModal?.setAttribute('hidden', '')
        }

        checkoutClosers.forEach((btn) => btn.addEventListener('click', closeCheckoutModal))

        cartToggle?.addEventListener('click', async () => {
          await fetchCart()
          openCart()
        })

        cartClosers.forEach((btn) => btn.addEventListener('click', closeCart))

        cartOverlay?.addEventListener('click', closeCart)

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') {
            if (checkoutModal && !checkoutModal.hasAttribute('hidden')) {
              closeCheckoutModal()
              return
            }
            if (cartDrawer?.classList.contains('open')) {
              closeCart()
            }
          }
        })

        document.addEventListener('cart:updated', fetchCart)

        checkoutBtn?.addEventListener('click', async () => {
          try {
            const res = await fetch(backendUrl('/api/cart/checkout/'), {
              method: 'POST',
              credentials: 'include',
            })
            const data = await res.json()
            showCheckoutModal(data.details || {})
          } catch {
            window.showStyledAlert?.('Error al obtener datos de pago.', 'Error')
          }
        })

        fetchCart()
      })()
    </script>
  </body>
</html>
