---
import '../styles/global.css'
import { Icon } from 'astro-icon/components' 

const { title = 'Constant Archivos Digitales', description = 'Archivos digitales para imprimir o dibujar — cuadernas, libretas, novelas gráficas y más.', page = 'inicio', image = '/static/web/assets/logo.webp' } = Astro.props
const currentYear = new Date().getFullYear()
const rawVersion = (import.meta.env.PUBLIC_APP_VERSION || '').trim()
const appVersion = rawVersion ? (rawVersion.startsWith('v') ? rawVersion : `v${rawVersion}`) : 'dev'
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://constantdigitales.com'
const canonical = new URL(Astro.url.pathname, siteUrl).href
const navItems = [
  { id: 'inicio', label: 'Inicio', href: '/' },
  { id: 'productos', label: 'Productos', href: '/productos/' },
  { id: 'uso', label: 'Uso', href: '/uso/' },
  // { id: 'canva', label: 'Canva', href: '/canva/' },
  { id: 'gratis', label: 'Gratis', href: '/gratis/' },
  { id: 'cuenta', label: 'Cuenta', href: '/cuenta/' },
  { id: 'contacto', label: 'Contacto', href: '/contacto/' },
]

const asset = (path) => `/${path}`
---

<!doctype html>
<html lang="es">
 
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/static/web/assets/favicon.svg?v=3" />
    <link rel="icon" type="image/x-icon" href="/static/web/assets/favicon.ico?v=3" sizes="any" />
    <link rel="shortcut icon" href="/static/web/assets/favicon.svg?v=3" />
    <link rel="apple-touch-icon" href="/static/web/assets/favicon.svg?v=3" />
    <meta name="msapplication-TileColor" content="#ffffff" />
    <meta name="theme-color" content="#ffffff" />

    <!-- Preconnect to font origins for faster cross-origin requests -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Google Fonts with font-display:swap -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=Great+Vibes&family=PT+Serif:ital,wght@0,400;0,700;1,400;1,700&display=swap"
    />

    <!-- SEO -->
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, siteUrl).href} />
    <meta property="og:locale" content="es_CL" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Constant Archivos Digitales",
      "url": siteUrl,
      "logo": new URL('/static/web/assets/logo.webp', siteUrl).href,
      "description": description,
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer service",
        "url": `${siteUrl}/contacto/`
      }
    })} />
  </head>
  <body
    style={`--ribbon-unsel: url('${asset('static/web/assets/ribbon-unsel.svg')}'); --ribbon-sel: url('${asset('static/web/assets/ribbon-sel.svg')}')`}
  >
    <div class="page-wrap">
      <img src={asset('static/web/assets/g51.svg')} alt="" class="decor decor-top-right" aria-hidden="true" width="550" height="155" />
      <img src={asset('static/web/assets/g45.webp')} alt="" class="decor decor-leaf-left" aria-hidden="true" width="80" height="140" />

      <header class="site-header">
        <a href="/" class="home-link">
          <div class="brand">
            <img src={asset('static/web/assets/logo.webp')} alt="Logo" class="logo" width="110" height="110" fetchpriority="high" />
            <div class="site-title">
              <img src={asset('static/web/assets/g345.webp')} alt="Constant Archivos Digitales" width="190" height="89" />
            </div>
          </div>
        </a>
        <button class="hamburger" aria-label="Abrir menu" aria-expanded="false" data-menu-toggle>
          <span></span><span></span><span></span>
        </button>
      </header>

      <nav class="mobile-nav" aria-label="Navegacion movil" data-mobile-nav>
        <ul>
          {navItems.map((item) => (
            <li>
              <a href={item.href} data-nav-id={item.id} class={page === item.id ? 'active' : ''} aria-current={page === item.id ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))}
          <li>
            <a href="#" data-auth-tab>Iniciar sesión</a>
          </li>
          <li data-publish-nav hidden>
            <a href="/publicar/" data-publish-tab class={page === 'publicar' ? 'active' : ''} aria-current={page === 'publicar' ? 'page' : undefined}>Publicar</a>
          </li>
        </ul>
      </nav>

      <aside class="side-nav">
        <ul>
          {navItems.map((item) => (
            <li>
              <a href={item.href} data-nav-id={item.id} class={page === item.id ? 'active' : ''} aria-current={page === item.id ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))}
          <li>
            <a href="#" data-auth-tab>Iniciar sesión</a>
          </li>
          <li data-publish-nav hidden>
            <a href="/publicar/" data-publish-tab class={page === 'publicar' ? 'active' : ''} aria-current={page === 'publicar' ? 'page' : undefined}>Publicar</a>
          </li>
        </ul>
      </aside>

      <slot />
    </div>

    <div class="auth-modal" data-auth-modal hidden>
      <div class="auth-modal__backdrop" data-auth-close></div>
      <div class="auth-modal__panel" role="dialog" aria-modal="true" aria-labelledby="auth-modal-title">
        <button class="auth-modal__close" type="button" aria-label="Cerrar" data-auth-close>×</button>

        <section data-auth-view="login">
          <h3 id="auth-modal-title">Iniciar sesión</h3>
          <form class="auth-form" data-login-form>
            <label for="login-identifier">Usuario o email</label>
            <input id="login-identifier" name="identifier" type="text" required />

            <label for="login-password">Contraseña</label>
            <input id="login-password" name="password" type="password" required />

            <button class="btn" type="submit">Iniciar sesión</button>
            <button class="auth-link" type="button" data-open-register>
              ¿No tienes cuenta de usuario? Regístrate aquí
            </button>
          </form>
        </section>

        <section data-auth-view="register" hidden>
          <h3 id="auth-modal-title">Registrarse</h3>
          <form class="auth-form" data-register-form>
            <label for="register-username">Nombre de usuario</label>
            <input id="register-username" name="username" type="text" required minlength="3" />

            <label for="register-email">Email</label>
            <input id="register-email" name="email" type="email" required />

            <label for="register-nombre">Nombre</label>
            <input id="register-nombre" name="nombre" type="text" required />

            <label for="register-apellido">Apellido</label>
            <input id="register-apellido" name="apellido" type="text" required />

            <label for="register-pais">País</label>
            <input id="register-pais" name="pais" type="text" required />

            <label for="register-password">Contraseña</label>
            <input id="register-password" name="password" type="password" required minlength="8" />

            <label for="register-password-confirm">Confirmar contraseña</label>
            <input id="register-password-confirm" name="password_confirm" type="password" required minlength="8" />

            <button class="btn" type="submit">Crear cuenta</button>
            <button class="auth-link" type="button" data-open-login>
              ¿Ya tienes cuenta? Inicia sesión aquí
            </button>
          </form>
        </section>

        <p class="auth-message" data-auth-message aria-live="polite"></p>
      </div>
    </div>

    <div class="confirm-modal" data-confirm-modal hidden>
      <div class="confirm-modal__backdrop" data-confirm-cancel></div>
      <div class="confirm-modal__panel" role="dialog" aria-modal="true" aria-labelledby="confirm-modal-title">
        <h3 id="confirm-modal-title">Confirmación</h3>
        <p data-confirm-message></p>
        <div class="confirm-modal__actions">
          <button class="btn btn-secondary" type="button" data-confirm-cancel>Cancelar</button>
          <button class="btn" type="button" data-confirm-accept>Aceptar</button>
        </div>
      </div>
    </div>

    <footer class="site-footer">
      <img src={asset('static/web/assets/g40.svg')} alt="" class="decor decor-bottom-left" aria-hidden="true" width="380" height="299" loading="lazy" />
      <p>Constant Archivos Digitales © {currentYear} · {appVersion}</p>
      <p><a href="/politica-privacidad/">Política de privacidad</a></p>
      <p class="footer-credit">
        Web construida por <Icon name=lucide:github class='w-6 h-6 hover:text-pink-600'/> <a href="https://github.com/nbazaes">nbazaes</a>
      </p>
    </footer>

    <script defer src="/auth.js"></script>
  </body>
</html>
